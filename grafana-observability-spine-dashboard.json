        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 36 },
      "id": 30,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showCommonLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "title": "Recent Error Logs",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{app=~\"code-server|oauth2-proxy|caddy\"} |= \"error\" | json | level=\"error\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 36 },
      "id": 31,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showCommonLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "title": "Slow Query Logs (>100ms)",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{app=\"postgres\"} |= \"duration\" | regexp `duration: (?P<duration>[\\d.]+) ms` | duration > 100",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 500,
      "title": "🔍 Distributed Trace Correlations",

# Production Environment Configuration
# Copy to .env.production and fill in values

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=code_server
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Application
NODE_ENV=production
LOG_LEVEL=info
DEBUG=false

# Code Server
CODE_SERVER_PASSWORD=CHANGE_ME_PASSWORD
CODE_SERVER_BIND_ADDR=0.0.0.0
CODE_SERVER_PORT=8080
CODE_SERVER_CERT=/etc/code-server/cert.pem
CODE_SERVER_CERT_KEY=/etc/code-server/key.pem

# Grafana
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GF_USERS_ALLOW_SIGN_UP=false

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#alerts

# PagerDuty
PAGERDUTY_KEY=CHANGE_ME_PAGERDUTY_KEY

# Monitoring
PROMETHEUS_RETENTION_DAYS=30
PROMETHEUS_SCRAPE_INTERVAL=15s

# Performance Targets
SLO_AVAILABILITY_TARGET=0.999
SLO_LATENCY_P99_TARGET_MS=500
SLO_ERROR_RATE_TARGET=0.001

# Feature Flags
FEATURE_ML_SEMANTIC_SEARCH=true
FEATURE_DISTRIBUTED_TRACING=true
FEATURE_AUTO_SCALING=true
FEATURE_CACHING=true

# Security
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_STRING
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_STRING

# Third-party APIs
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME

# Backup & Recovery
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Logging
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_MAX_SIZE=100m
LOG_RETENTION_DAYS=30

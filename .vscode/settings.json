{
  "// ═══════════════════════════════════════════════════════════════════════════": "",
  "// VS CODE CRASH PREVENTION CONFIGURATION (PRODUCTION-GRADE)": "",
  "// Last Updated: April 16, 2026 | Third Crash - Terminal Blocking Enforcement": "",
  "// ═══════════════════════════════════════════════════════════════════════════": "",

  "// ░░░ CRITICAL: Window & Session Management (Prevents process spawning) ░░░": "",
  "window.restoreWindows": "none",
  "window.restoreFullscreen": false,
  "window.newWindowProfile": "",
  "terminal.integrated.persistentSessionInWorkspace": false,
  "terminal.integrated.persistentSessionName": "",
  "terminal.integrated.showExitAlert": false,

  "// ░░░ CRITICAL: Terminal Limits (Prevent resource exhaustion) ░░░": "",
  "terminal.integrated.splitCwd": "workspaceRoot",
  "terminal.integrated.closeOnExit": "always",
  "terminal.integrated.enableFileLinks": "notRemote",
  "terminal.integrated.scrollback": 50,
  "terminal.integrated.automationProfile.linux": "",
  "terminal.integrated.automationProfile.osx": "",
  "terminal.integrated.automationProfile.windows": "",
  "terminal.integrated.defaultLocation": "editor",
  "terminal.integrated.allowChords": false,
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.env.windows": {},
  "terminal.integrated.env.linux": {},
  "terminal.integrated.env.osx": {},
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.defaultProfile.linux": "sh",
  "terminal.integrated.defaultProfile.osx": "bash",
  "terminal.integrated.profiles.windows": {},
  "terminal.integrated.profiles.linux": {},
  "terminal.integrated.profiles.osx": {},

  "// ░░░ Memory Budget Enforcement (Issue #448) ░░░": "",
  "// Extension host memory capped via launch-vscode-budgeted.bat: --max-old-space-size=1024": "",
  "extensionHost.transportKind": "auto",
  "extensionHost.debugBrk": false,
  "extensionHost.enable": true,
  
  "// ░░░ File Watcher Performance (Issue #447) ░░░": "",
  "files.watcherPollingInterval": 5000,
  "files.watcherPollingStackDepth": 50,

  "// ░░░ File Watcher Exclusions (Prevent VSCode hangs on large directories) ░░░": "",
  "// Issue #447: Extended watcher exclusions for 40-60% CPU reduction": "",
  "files.watcherExclude": {
    "**/.git": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.git/index.lock": true,
    "**/.gitignore": true,
    "**/node_modules/**": true,
    "**/node_modules/.bin/**": true,
    "**/.terraform/**": true,
    "**/.terraform.lock.hcl": true,
    "**/terraform/.terraform/**": true,
    "**/terraform/terraform.tfstate*": true,
    "**/terraform/.terraformrc": true,
    "**/build/**": true,
    "**/dist/**": true,
    "**/target/**": true,
    "**/__pycache__/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/.env*": true,
    "**/.aws/**": true,
    "**/.ssh/**": true,
    "**/.kube/**": true,
    "**/.docker/**": true,
    "**/scripts.tar.gz": true,
    "**/*.log": true,
    "**/logs/**": true,
    "**/test-results/**": true,
    "**/coverage/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/.tox/**": true,
    "**/vendor/**": true,
    "**/*.tfplan": true,
    "**/*.zip": true,
    "**/*.tar.gz": true,
    "**/*.backup": true,
    "**/.backups/**": true,
    "**/grafana/data/**": true,
    "**/prometheus/data/**": true,
    "**/postgres/data/**": true,
    "**/redis/data/**": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.cache/**": true,
    "**/@snapshot/**": true,
    "**/@Recently-Snapshot/**": true,
    "**/tmp/**": true,
    "**/.tmp/**": true,
    "**/temp/**": true,
    "**/.temp/**": true,
    "**/*.swp": true,
    "**/*.swo": true,
    "**/*~": true,
    "**/.idea/**": true,
    "**/.vscode/**": true,
    "**/.vscode-insiders/**": true,
    "**/*.iml": true,
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings/**": true,
    "**/dist-electron/**": true,
    "**/.nuxt/**": true,
    "**/.next/**": true,
    "**/.out/**": true,
    "**/.cache-loader/**": true,
    "**/obj/**": true,
    "**/bin/**": true,
    "**/.gradle/**": true,
    "**/gradlew": true,
    "**/gradlew.bat": true,
    "**/.bundle/**": true,
    "**/Gemfile.lock": true,
    "**/pnpm-lock.yaml": true,
    "**/yarn.lock": true,
    "**/package-lock.json": true,
    "**/.pnpm-store/**": true,
    "**/backups-phase7b/**": true,
    "**/containerd/**": true,
    "**/docker-data/**": true,
    "**/ollama/blobs/**": true,
    "**/package-cache/**": true,
    "**/postgres-backups/**": true,
    "**/bower_components/**": true,
    "**/jspm_packages/**": true,
    "**/.sass-cache/**": true,
    "**/.less-cache/**": true,
    "**/.cmake-js/**": true,
    "**/cmake-build-*/**": true,
    "**/.venv-*/**": true,
    "**/.env.*.local": true,
    "**/.env.local": true,
    "**/.env.test.local": true,
    "**/.env.production.local": true
  },

  "// ░░░ Language Server Management (Prevent extension-host crashes) ░░░": "",
  "extensions.autoCheckUpdates": false,
  "extensions.autoUpdate": false,
  "extensions.verifySignature": false,
  "telemetry.telemetryLevel": "off",
  "debugProtocol.logAllCommunication": false,
  "debug.extensionHost.environments": [],
  "[python]": {
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {},
    "editor.defaultFormatter": "none"
  },
  "[json]": {
    "editor.formatOnSave": false
  },
  "[yaml]": {
    "editor.formatOnSave": false
  },
  "json.validateAgainstSchema": false,
  "yaml.validate": false,
  "yaml.maxComputeItems": 100,
  "search.followSymlinks": false,
  "search.maxResults": 500,
  "search.useParentIgnoreFiles": true,

  "// ░░░ Memory & Performance Optimization ░░░": "",
  "editor.largeFileOptimizations": true,
  "editor.links": false,
  "editor.lightbulb.enabled": "off",
  "editor.inlayHints.enabled": false,
  "breadcrumbs.enabled": false,
  "outline.enabled": false,
  "timeline.enabled": false,
  "editor.occurrencesHighlight": "off",
  "editor.wordBasedSuggestions": "off",
  "editor.codeLens": false,
  "[Log]": {
    "editor.wordWrap": "off",
    "editor.minimap.enabled": false
  },

  "// ░░░ Disable Heavy Extensions (Pre-configured safe set) ░░░": "",
  "extensions.recommendations": [],
  "extensions.ignoreRecommendations": true,
  "extensions.extensionKind": {
    "ms-python.python": ["workspace"],
    "ms-python.vscode-pylance": ["workspace"],
    "golang.go": ["workspace"],
    "rust-lang.rust-analyzer": ["workspace"]
  },
  "[python]": {
    "editor.defaultFormatter": "none",
    "editor.codeActionsOnSave": {},
    "editor.formatOnSave": false,
    "editor.formatOnPaste": false
  },

  "// ░░░ Workspace Isolation (Security & Stability) ░░░": "",
  "security.workspace.trust.enabled": false,
  "security.workspace.trust.startupPrompt": "never",
  "security.workspace.trust.untrustedFiles": "open",
  "security.lockRequiredExtensions": [],
  "task.problemMatchers.neverPrompt": true,
  "task.allowAutomaticTasks": "off",
  "task.autoRunProblemMatchers": false,

  "// ░░░ Git Optimization (Issue #447) ░░░": "",
  "git.autoRepositoryDetection": "openEditors",
  "git.decorations.enabled": false,
  "git.autofetch": false,
  "git.fetchOnPull": false,
  "git.ignoreRepositoryVersion": true,
  "git.fetchOnPull": false,
  "git.fetchAll": false,
  "git.ignoreLimitWarning": true,
  "git.useEditorAsCommitUI": true,
  "git.inputValidationLength": 72,
  "git.ignoreMissingGitWarning": true,
  "git.detectSubmodules": false,
  "git.showProgress": false,
  "git.showPushSuccessNotification": false,
  "git.rebaseWhenSync": false,
  "git.branchProtection": [],
  "git.ignoreLimitWarning": true,
  "git.terminalGitEditor": true,

  "// ░░░ Workbench Editor Management ░░░": "",
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 8,
  "workbench.editor.limit.perEditorGroup": true,
  "workbench.tree.renderIndentGuides": "none",

  "// ░░░ Search Optimization (Issue #447) ░░░": "",
  "search.exclude": {
    "**/node_modules": true,
    "**/node_modules/**": true,
    "**/dist": true,
    "**/dist/**": true,
    "**/.terraform": true,
    "**/terraform/.terraform": true,
    "**/terraform/**/.terraform": true,
    "**/logs": true,
    "**/logs/**": true,
    "**/test-results": true,
    "**/test-results/**": true,
    "**/coverage": true,
    "**/coverage/**": true,
    "**/*.tfstate": true,
    "**/*.tfstate.*": true,
    "**/grafana/data": true,
    "**/prometheus/data": true,
    "**/postgres/data": true,
    "**/redis/data": true,
    "**/.git/objects": true,
    "**/.git/objects/**": true,
    "**/__pycache__": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache": true,
    "**/.pytest_cache/**": true,
    "**/.tox": true,
    "**/.tox/**": true,
    "**/build": true,
    "**/build/**": true,
    "**/target": true,
    "**/target/**": true,
    "**/tmp": true,
    "**/tmp/**": true
  },
  "search.useIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "search.smartCase": true,
  "search.maxResults": 500,
  "search.useParentIgnoreFiles": true,
  "search.collapseResults": "alwaysCollapse",
  "search.seedOnFocus": true,
  "search.searchOnType": false,

  "// ░░░ Crash Recovery Settings ░░░": "",
  "workbench.crashReporter.show": false,
  "workbench.enableExperiments": false,
  "workbench.view.alwaysShowHeaderActions": false,

  "// ░░░ Debug/Testing ░░░": "",
  "debug.console.closeOnEnd": true,
  "debug.allowBreakpointsEverywhere": false,
  "accessibility.signals.terminalBell": {
    "sound": "off"
  },
  "terminal.integrated.enableVisualBell": false,

  "// ░░░ SPEED OPTIMIZATION SECTION (Issue #447) ░░░": "",
  "// Autocomplete & IntelliSense Optimization": "",
  "[javascript]": { "editor.maxTokenizationLineLength": 100000 },
  "[typescript]": { "editor.maxTokenizationLineLength": 100000 },
  "[python]": { 
    "editor.maxTokenizationLineLength": 100000,
    "editor.formatOnPaste": false,
    "editor.formatOnSave": false
  },
  "[json]": { "editor.maxTokenizationLineLength": 100000 },
  "editor.suggest.localityBonus": true,
  "editor.suggest.maxVisibleSuggestions": 12,
  "editor.suggestOnTriggerCharacters": true,
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },
  "editor.acceptSuggestionOnEnter": "off",
  "editor.acceptSuggestionOnCommitCharacter": false,

  "// Rendering & UI Optimization": "",
  "editor.minimap.enabled": false,
  "editor.minimap.maxColumn": 0,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.smoothScrolling": false,
  "editor.mouseWheelSpeed": 5,
  "workbench.productIconBadge": "off",
  "explorer.decorations.enabled": false,
  "scm.decorations.enabled": false,
  
  "// Syntax Highlighting & Grammar Optimization": "",
  "editor.semanticHighlighting.enabled": false,
  "editor.tokenColorCustomizations": {},
  "textMateRules": [],
  
  "// File Operations Optimization": "",
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/.terraform": true
  },
  "files.simpleDialog.enable": true,
  "files.hotExit": "onExit",
  "files.autoSave": "onFocusChange",
  "files.associations": {
    "*.tfvars": "hcl",
    "*.hcl": "hcl",
    "docker-compose*": "yaml"
  },

  "// Update & Notification Optimization": "",
  "update.mode": "none",
  "update.showReleaseNotes": false,
  "update.enableWindowsBackgroundUpdates": false,
  "extensions.closeExtensionDetailsOnViewChange": true,

  "// Scrolling & Animation Optimization": "",
  "editor.fastScrollSensitivity": 5,
  "editor.scrollBeyondLastLine": false,
  "editor.cursorSmoothCaretAnimation": "off",
  "workbench.list.smoothScrolling": false,
  "workbench.tree.expandMode": "singleClick",

  "// Editor Configuration": "",
  "editor.fontLigatures": false,
  "editor.foldingStrategy": "indentation",
  "editor.dragAndDrop": false,
  "editor.parameterHints.enabled": false,
  "editor.bracketPairColorization.enabled": false,
  "editor.guides.bracketPairs": false,

  "// Markdown & Preview Optimization": "",
  "[markdown]": {
    "editor.quickSuggestions": {
      "other": false,
      "comments": false,
      "strings": false
    }
  },
  "markdown.preview.breaks": false,
  "markdown.preview.doubleClickToTogglePreview": false,

  "// Power User Shortcuts": "",
  "editor.defaultFormatter": "none",
  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  "editor.formatOnType": false,
  "editor.guides.indentation": false,

  "// ░░░ Multi-Session Process Isolation (#444) ░░░": "",
  "// NAS workspace watcher exclusions (prep for #445)": "",
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.venv/**": true,
    "**/__pycache__/**": true,
    "**/*.log": true,
    "**/.recycle/**": true,
    "**/@snapshot/**": true,
    "**/@Recently-Snapshot/**": true
  },
  "// Isolate extension recommendations per workspace (avoids cross-workspace noise)": "",
  "extensions.recommendations": [],
  "extensions.ignoreRecommendations": true,
  "// Prevent Copilot context bleed across concurrent windows": "",
  "github.copilot.enable": { "*": true },
  "github.copilot.advanced": {},

  "// ─── Folder Taxonomy / Root Hygiene (Issue #613) ──────────────────────────": "",
  "// Root should contain only entrypoints. Docs, scripts, config go in subdirectories.": "",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "docker-compose.yml": "docker-compose.*.yml,docker-compose-*.yml",
    "Caddyfile": "Caddyfile.*",
    "Makefile": "Makefile.*",
    ".env.defaults": ".env.example,.env.template,.env",
    "main.tf": "*.tf,*.tf.disabled,terraform.tfvars.example,tfplan"
  },
  "// Highlight 'off-limits' root-level files with a visual cue": "",
  "files.associations": {
    "PHASE-*.md": "markdown",
    "MIGRATION-*.md": "markdown",
    "DEPLOYMENT-CHECKLIST-*.md": "markdown"
  }
}

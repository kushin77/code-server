[Unit]
Description=Code-Server Production Health Check
Documentation=file:///opt/code-server-enterprise/docs/HEALTH-CHECK-MONITORING.md
After=docker.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/code-server-enterprise
ExecStart=/bin/bash /opt/code-server-enterprise/scripts/health-check.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=health-check
TimeoutStartSec=60

# Resource limits
CPUQuota=20%
MemoryMax=256M
TasksMax=32

[Install]
WantedBy=multi-user.target

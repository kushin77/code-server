# .env.template
# Canonical environment configuration for on-prem deployment.
# Copy to .env on the deployment host and populate values from GSM.

# Core identity
DOMAIN=kushnir.cloud
IDE_DOMAIN=ide.kushnir.cloud
ACME_EMAIL=ops@kushnir.cloud

# Topology (must align with environments/production/hosts.yml)
DEPLOY_HOST=192.168.168.31
REPLICA_HOST=192.168.168.42
VIP_HOST=192.168.168.30
DEPLOY_USER=akushnir

# Authentication and OAuth (required)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_IDE_GOOGLE_CLIENT_ID=
OAUTH2_IDE_GOOGLE_CLIENT_SECRET=
OAUTH2_PROXY_IDE_REDIRECT_URL=https://ide.kushnir.cloud/oauth2/callback
OAUTH2_PROXY_PORTAL_REDIRECT_URL=https://kushnir.cloud/oauth2/callback

# Cloudflare automation (optional, for setup scripts/CI)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=

# IDE and runtime credentials (required)
CODE_SERVER_PASSWORD=
POSTGRES_DB=codeserver
POSTGRES_USER=codeserver
POSTGRES_PASSWORD=
GRAFANA_PASSWORD=

# Terraform-sensitive inputs (required when running terraform apply)
# Export as environment variables (example):
#   export TF_VAR_grafana_admin_password="$GRAFANA_PASSWORD"
#   export TF_VAR_kong_database_password="..."
#   export TF_VAR_postgres_password="$POSTGRES_PASSWORD"
TF_VAR_grafana_admin_password=
TF_VAR_kong_database_password=
TF_VAR_postgres_password=

# Session broker limits
SESSION_BROKER_LOG_LEVEL=info
SESSION_CPU_LIMIT=2.0
SESSION_MEMORY_LIMIT=4g
SESSION_STORAGE_LIMIT=50g

# Optional integrations
GITHUB_TOKEN=
GSM_PROJECT=gcp-eiq
GSM_SECRET_NAME=github-token
GIT_CREDENTIAL_GSM_CANONICAL_SECRET_NAME=github-token

# Optional HAProxy stats auth (required if using config/haproxy.cfg stats endpoint)
HAPROXY_STATS_USER=
HAPROXY_STATS_PASSWORD=

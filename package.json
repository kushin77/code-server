{
  "name": "code-server-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.2.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": "9.2.0"
  },
  "scripts": {
    "bootstrap": "pnpm install --frozen-lockfile",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "type-check": "pnpm -r --if-present type-check",
    "validate:lockfile": "bash scripts/ci/check-pnpm-lockfile.sh"
  }
}{
  "name": "code-server-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "bootstrap": "pnpm install --frozen-lockfile",
    "install:workspace": "pnpm install",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "ci:lockfile": "pnpm install --frozen-lockfile --ignore-scripts"
  }
}

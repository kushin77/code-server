{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.2.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Phase 26-B: Analytics Dashboard - API Usage, Performance & Cost",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (24h)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "justifyMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short", "mappings": [] } },
      "targets": [{ "expr": "increase(graphql_requests_total[24h])", "legendFormat": "Requests", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (5m)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.001 }, { "color": "red", "value": 0.005 }] }, "unit": "percentunit", "decimals": 3 } },
      "targets": [{ "expr": "rate(graphql_errors_total[5m]) / rate(graphql_requests_total[5m])", "legendFormat": "Error Rate", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p99 Latency (5m)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.08 }, { "color": "red", "value": 0.1 }] }, "unit": "s" } },
      "targets": [{ "expr": "histogram_quantile(0.99, rate(graphql_request_duration_seconds_bucket[5m]))", "legendFormat": "p99 Latency", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Rate Limit Violations (5m)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }, "unit": "short" } },
      "targets": [{ "expr": "increase(rate_limit_violations_total[5m])", "legendFormat": "Violations", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Cost / Hour (est.)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "currencyUSD", "decimals": 4 } },
      "targets": [{ "expr": "sum(rate(rate_limit_requests_total{tier='pro'}[1h])) * 0.029 / 1000 + sum(rate(rate_limit_requests_total{tier='enterprise'}[1h])) * 0.01 / 1000", "legendFormat": "Hourly Cost", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 400 }, { "color": "red", "value": 490 }] }, "unit": "short" } },
      "targets": [{ "expr": "sum(rate_limit_concurrent_requests)", "legendFormat": "Connections", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Request Volume by Tier (req/sec)",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "expr": "rate(rate_limit_requests_total{tier='free'}[5m])", "legendFormat": "Free Tier", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "rate(rate_limit_requests_total{tier='pro'}[5m])", "legendFormat": "Pro Tier", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "rate(rate_limit_requests_total{tier='enterprise'}[5m])", "legendFormat": "Enterprise Tier", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "Requests by Tier (24h)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "orientation": "horizontal", "legend": { "displayMode": "list" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "targets": [
        { "expr": "increase(rate_limit_requests_total{tier='free'}[24h])", "legendFormat": "Free", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "increase(rate_limit_requests_total{tier='pro'}[24h])", "legendFormat": "Pro", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "increase(rate_limit_requests_total{tier='enterprise'}[24h])", "legendFormat": "Enterprise", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Latency Percentiles (API)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(graphql_request_duration_seconds_bucket[5m]))", "legendFormat": "p50", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "histogram_quantile(0.95, rate(graphql_request_duration_seconds_bucket[5m]))", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "histogram_quantile(0.99, rate(graphql_request_duration_seconds_bucket[5m]))", "legendFormat": "p99", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Error Rate by Type",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "rate(graphql_errors_total{type='RATE_LIMIT_EXCEEDED'}[5m]) / rate(graphql_requests_total[5m])", "legendFormat": "Rate Limited (429)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "rate(graphql_errors_total{type='INTERNAL_ERROR'}[5m]) / rate(graphql_requests_total[5m])", "legendFormat": "Internal Errors (5xx)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "rate(graphql_errors_total{type='VALIDATION'}[5m]) / rate(graphql_requests_total[5m])", "legendFormat": "Validation Errors (4xx)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Cost Accumulation (USD)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "custom": { "lineWidth": 2, "fillOpacity": 15 } } },
      "targets": [
        { "expr": "sum(increase(rate_limit_requests_total{tier='pro'}[1h])) * 0.029 / 1000", "legendFormat": "Pro Tier Cost", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "sum(increase(rate_limit_requests_total{tier='enterprise'}[1h])) * 0.01 / 1000", "legendFormat": "Enterprise Tier Cost", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Rate Limit Violations (over time)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "increase(rate_limit_violations_total{tier='free'}[5m])", "legendFormat": "Free Violations", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "increase(rate_limit_violations_total{tier='pro'}[5m])", "legendFormat": "Pro Violations", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "increase(rate_limit_violations_total{tier='enterprise'}[5m])", "legendFormat": "Enterprise Violations", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 40,
      "type": "gauge",
      "title": "Free Tier Token Usage (%)",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "percentage", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }, "min": 0, "max": 60, "unit": "short" } },
      "targets": [{ "expr": "rate(rate_limit_requests_total{tier='free'}[1m]) * 60", "legendFormat": "Free req/min", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 41,
      "type": "gauge",
      "title": "Pro Tier Token Usage (%)",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "percentage", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }, "min": 0, "max": 1000, "unit": "short" } },
      "targets": [{ "expr": "rate(rate_limit_requests_total{tier='pro'}[1m]) * 60", "legendFormat": "Pro req/min", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 42,
      "type": "gauge",
      "title": "Enterprise Token Usage (%)",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "percentage", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }, "min": 0, "max": 10000, "unit": "short" } },
      "targets": [{ "expr": "rate(rate_limit_requests_total{tier='enterprise'}[1m]) * 60", "legendFormat": "Enterprise req/min", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 43,
      "type": "table",
      "title": "Top Organizations by Usage (24h)",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "expr": "topk(10, increase(rate_limit_requests_total[24h]))", "legendFormat": "{{org_id}}", "instant": true, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["phase-26", "analytics", "rate-limiting", "production"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "hide": 0,
        "includeAll": true,
        "name": "tier",
        "options": [],
        "query": "label_values(rate_limit_requests_total, tier)",
        "refresh": 1,
        "type": "query",
        "label": "Tier"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Phase 26 - API Analytics Dashboard",
  "uid": "phase26-analytics-v1",
  "version": 1
}

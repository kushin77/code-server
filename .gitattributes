# .gitattributes — enforce consistent line endings
# All scripts must be LF on all platforms to run correctly on Linux production systems
# LINUX MANDATORY: No Windows-only development allowed

# Catch-all: normalize all text files to LF (prevents CRLF artifacts in WSL/Windows)
*           text=auto eol=lf

*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile* text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
Makefile    text eol=lf
Caddyfile*  text eol=lf

# Text files — normalize to LF
*.md        text eol=lf
*.tf        text eol=lf
*.json      text eol=lf
*.cfg       text eol=lf

# Binary files — no normalization
*.vsix      binary
*.png       binary
*.jpg       binary

# ════════════════════════════════════════════════════════════════════════════
# Code-Server Enterprise Configuration
# On-prem VSCode server at 192.168.168.31 behind Cloudflare Tunnel
# Usage: cp .env.example .env && edit .env with your values
# ════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Code-Server Authentication
# ─────────────────────────────────────────────────────────────────────────────
CODE_SERVER_PASSWORD=change-me-strong-password-min-20-chars

# ─────────────────────────────────────────────────────────────────────────────
# Networking & Domain
# ─────────────────────────────────────────────────────────────────────────────
DOMAIN=ide.kushnir.cloud
ACME_EMAIL=security@kushnir.cloud

# ─────────────────────────────────────────────────────────────────────────────
# OAuth2 Proxy / Google Authentication (for code-server access)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH2_PROXY_COOKIE_SECRET=your-32-hex-char-secret-from-openssl-rand-hex-16

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Integration
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# ─────────────────────────────────────────────────────────────────────────────
# Ollama LLM Configuration (GPU acceleration)
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_NUM_THREAD=16
OLLAMA_NUM_GPU=1
OLLAMA_GPU_LAYERS=99
OLLAMA_FLASH_ATTENTION=1
OLLAMA_NUM_PARALLEL=4

# ─────────────────────────────────────────────────────────────────────────────
# NAS Storage
# ─────────────────────────────────────────────────────────────────────────────
NAS_HOST=192.168.168.56
NAS_EXPORT_PATH=/export

# ─────────────────────────────────────────────────────────────────────────────
# P1 #388 - OIDC Provider Configuration (Phase 1 IAM Implementation)
# ─────────────────────────────────────────────────────────────────────────────
# Provider selection: google, keycloak, or github
OAUTH2_PROVIDER=google

# Google OAuth2 (Primary provider - get from GCP Console)
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=

# OIDC Issuer and Redirect (Google endpoints)
OAUTH2_OIDC_ISSUER_URL=https://accounts.google.com
OAUTH2_REDIRECT_URL=http://192.168.168.31:4180/oauth2/callback

# oauth2-proxy cookie/token secrets (MUST be 16, 24, or 32 bytes hex)
# Generate with: openssl rand -hex 16
OAUTH2_COOKIE_SECRET=
OAUTH2_TOKEN_SECRET=

# Keycloak (Optional fallback provider)
KEYCLOAK_HOST=keycloak.192.168.168.31.nip.io
KEYCLOAK_PORT=8180
KEYCLOAK_REALM=acme-corp
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_CLIENT_SECRET=

# JWT Token Configuration
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800
ID_TOKEN_TTL=3600

# MFA Enforcement
MFA_REQUIRED_FOR_ADMIN=true
MFA_REQUIRED_FOR_OPERATOR=false
MFA_REQUIRED_FOR_VIEWER=false

# Feature Flags
FEATURE_OIDC_SETUP=true
FEATURE_SERVICE_AUTH=false
FEATURE_RBAC=false
FEATURE_AUDIT_LOGGING=false

# ─────────────────────────────────────────────────────────────────────────────
# Monitoring & Observability
# ─────────────────────────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=15d
GRAFANA_ADMIN_PASSWORD=admin123
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Security & Secrets (use Google Secret Manager in production)
# ─────────────────────────────────────────────────────────────────────────────
GSM_PROJECT_ID=your-gcp-project-id
GSM_SECRETS_PATH=projects/your-project/secrets

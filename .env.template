# Code-Server Enterprise - Environment Configuration Template
# Status: IaC Automation Ready
# Generated by: automated-env-generator.sh
#
# CONFIGURATION VIA ENVIRONMENT VARIABLES ONLY - NO HARDCODING
# All credentials are auto-generated by the deployment script
# NEVER commit .env to Git (it contains secrets)

# ═══════════════════════════════════════════════════════════════
# REQUIRED: Domain and Host Configuration
# ═══════════════════════════════════════════════════════════════

# Target domain for deployment
DOMAIN=ide.kushnir.cloud

# Target deployment host (primary host is 192.168.168.31)
DEPLOY_HOST=192.168.168.31

# SSH user for remote deployment
DEPLOY_USER=akushnir

# Environment name (production/staging/development)
DEPLOY_ENV=production

# ═══════════════════════════════════════════════════════════════
# AUTO-GENERATED: Security Credentials
# ═══════════════════════════════════════════════════════════════
# These are created automatically by automated-env-generator.sh
# Do not edit - they are randomly generated on each deployment

# Code-Server login password (32-byte base64 random)
CODE_SERVER_PASSWORD=GENERATED_BY_SCRIPT

# OAuth2-Proxy session cookie secret (32-byte base64 random)
OAUTH2_PROXY_COOKIE_SECRET=GENERATED_BY_SCRIPT

# Redis authentication password (16-byte base64 random)
REDIS_PASSWORD=GENERATED_BY_SCRIPT

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: ACME / Let's Encrypt Configuration
# ═══════════════════════════════════════════════════════════════
# Leave blank to use self-signed bootstrap certificates
# Set to enable automatic Let's Encrypt provisioning via Caddy ACME

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@kushnir.cloud

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: CloudFlare DNS Configuration
# ═══════════════════════════════════════════════════════════════
# Leave blank to skip DNS automation (non-blocking if not set)
# Set these to enable automatic DNS record management

# CloudFlare API token (get from https://dash.cloudflare.com/profile/api-tokens)
CLOUDFLARE_API_TOKEN=

# CloudFlare Zone ID (get from domain dashboard)
CLOUDFLARE_ZONE_ID=

# ═══════════════════════════════════════════════════════════════
# REQUIRED: Google OAuth Configuration
# ═══════════════════════════════════════════════════════════════
# Required for OAuth2 authentication
# Get from: Google Cloud Console → APIs & Services → Credentials

# Google OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=

# Google OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET=

# OAuth2-Proxy settings (auto-configured)
OAUTH2_PROXY_OIDC_ISSUER_URL=https://accounts.google.com
OAUTH2_PROXY_REDIRECT_URL=https://ide.kushnir.cloud/oauth2/callback

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: GitHub Configuration
# ═══════════════════════════════════════════════════════════════
# Get from: https://github.com/settings/tokens
# Scopes: read:user, user:email

GITHUB_TOKEN=

# ═══════════════════════════════════════════════════════════════
# SERVICE CONFIGURATION (Defaults - Usually OK)
# ═══════════════════════════════════════════════════════════════

CODE_SERVER_USER=coder
LOG_LEVEL=info

# Ollama (LLM backend)
OLLAMA_NUM_THREAD=6
OLLAMA_NUM_GPU=0

# Redis (cache/session store)
REDIS_BIND=127.0.0.1
REDIS_DATABASES=16
REDIS_MEMORY=512mb

# Workspace directory (code-server mounts this at /home/coder/workspace)
WORKSPACE_PATH=./workspace

# ═══════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════
#
# QUICK START (PRODUCTION):
# ========================
# 1. export DOMAIN="ide.kushnir.cloud"
# 2. export DEPLOY_HOST="192.168.168.31"
# 3. export DEPLOY_USER="akushnir"
# 4. export GOOGLE_CLIENT_ID="<your-client-id>"
# 5. export GOOGLE_CLIENT_SECRET="<your-client-secret>"
# 6. (Optional) export CLOUDFLARE_API_TOKEN="<token>"
# 7. (Optional) export CLOUDFLARE_ZONE_ID="<zone-id>"
# 8. Run: ./scripts/automated-deployment-orchestration.sh
#
# EVERYTHING IS AUTOMATED FROM HERE - NO MANUAL STEPS
#
# ═══════════════════════════════════════════════════════════════

#!/usr/bin/env bash
# git-credential-gsm — Git credential helper backed by GCP Secret Manager
#
# Implements the git credential helper protocol (get/store/erase).
# On `get`: fetches the GitHub PAT from GSM and returns it to git.
# On `store`/`erase`: no-op (GSM is the source of truth; PATs are not stored
#                     locally and are never written to ~/.git-credentials).
#
# Installation (run scripts/setup-git-credentials.sh):
#   sudo install -m755 scripts/git-credential-gsm /usr/local/bin/git-credential-gsm
#   git config --global credential.helper gsm
#
# Environment overrides:
#   GSM_PROJECT         GCP project ID (default: gcp-eiq)
#   GIT_CREDENTIAL_GSM_CANONICAL_SECRET_NAME  Canonical secret (default: github-token)
#   GSM_SECRET_NAME     Deprecated legacy override; treated as fallback candidate only
#   GSM_SECRET_CANDIDATES  Comma-separated secret candidates (default deterministic chain)
#   GIT_CREDENTIAL_GSM_ALLOW_ENV_FALLBACK  Allow GH_TOKEN/GITHUB_TOKEN fallback (default: true)
#   GIT_CREDENTIAL_GSM_STRICT              Fail on non-canonical source in production (default: false)
#   GIT_CREDENTIAL_GSM_ENV                 Optional context override (production|staging|dev)
#
# Requires: gcloud (Google Cloud SDK)
# Fallback: if GSM is unavailable, exits non-zero so git tries the next helper
#           in the chain (safe degradation).
set -euo pipefail

readonly GSM_PROJECT="${GSM_PROJECT:-gcp-eiq}"
readonly CANONICAL_GSM_SECRET_NAME="${GIT_CREDENTIAL_GSM_CANONICAL_SECRET_NAME:-github-token}"
readonly LEGACY_GSM_SECRET_NAME_OVERRIDE="${GSM_SECRET_NAME:-}"
readonly GSM_SECRET_CANDIDATES_RAW="${GSM_SECRET_CANDIDATES:-}"
readonly GIT_CREDENTIAL_GSM_ALLOW_ENV_FALLBACK="${GIT_CREDENTIAL_GSM_ALLOW_ENV_FALLBACK:-true}"
readonly GIT_CREDENTIAL_GSM_STRICT="${GIT_CREDENTIAL_GSM_STRICT:-false}"
readonly GIT_CREDENTIAL_GSM_ENV="${GIT_CREDENTIAL_GSM_ENV:-${ENVIRONMENT:-}}"
readonly GITHUB_HOST="github.com"

json_log() {
    local level="$1"
    local event="$2"
    local message="$3"
    local source="${4:-}"
    local candidate="${5:-}"

    printf '{"component":"git-credential-gsm","level":"%s","event":"%s","message":"%s","project":"%s","canonical_secret":"%s","source":"%s","candidate":"%s"}\n' \
        "$level" "$event" "$message" "$GSM_PROJECT" "$CANONICAL_GSM_SECRET_NAME" "$source" "$candidate" >&2
}

is_truthy() {
    case "${1,,}" in
        true|1|yes|y|on) return 0 ;;
        *) return 1 ;;
    esac
}

is_production_context() {
    case "${GIT_CREDENTIAL_GSM_ENV,,}" in
        prod|production) return 0 ;;
        *) return 1 ;;
    esac
}

unique_append_csv() {
    local needle="$1"
    local haystack="$2"

    if [[ -z "$needle" ]]; then
        echo "$haystack"
        return
    fi

    local IFS=','
    for item in $haystack; do
        if [[ "$item" == "$needle" ]]; then
            echo "$haystack"
            return
        fi
    done

    if [[ -z "$haystack" ]]; then
        echo "$needle"
    else
        echo "$haystack,$needle"
    fi
}

resolve_secret_chain() {
    local chain=""

    if [[ -n "$GSM_SECRET_CANDIDATES_RAW" ]]; then
        chain="$GSM_SECRET_CANDIDATES_RAW"
    fi

    # Always enforce canonical secret first for deterministic behavior.
    chain="$(unique_append_csv "$CANONICAL_GSM_SECRET_NAME" "$chain")"

    # Backward compatibility: legacy GSM_SECRET_NAME is candidate-only and cannot
    # redefine the canonical secret used by strict mode.
    if [[ -n "$LEGACY_GSM_SECRET_NAME_OVERRIDE" && "$LEGACY_GSM_SECRET_NAME_OVERRIDE" != "$CANONICAL_GSM_SECRET_NAME" ]]; then
        json_log "warn" "deprecated_override_used" "GSM_SECRET_NAME override detected; treating as fallback candidate only" "gsm" "$LEGACY_GSM_SECRET_NAME_OVERRIDE"
        chain="$(unique_append_csv "$LEGACY_GSM_SECRET_NAME_OVERRIDE" "$chain")"
    fi

    # Known legacy names (kept deterministic and explicit).
    chain="$(unique_append_csv "github-token" "$chain")"
    chain="$(unique_append_csv "prod-github-token" "$chain")"
    chain="$(unique_append_csv "prod-github-pat" "$chain")"
    chain="$(unique_append_csv "legacy-github-token" "$chain")"

    # Ensure canonical stays first without substring side effects.
    local reordered=""
    local item
    local IFS=','
    for item in $chain; do
        [[ -z "$item" ]] && continue
        if [[ "$item" != "$CANONICAL_GSM_SECRET_NAME" ]]; then
            reordered="$(unique_append_csv "$item" "$reordered")"
        fi
    done

    chain="$CANONICAL_GSM_SECRET_NAME"
    if [[ -n "$reordered" ]]; then
        chain="$chain,$reordered"
    fi
    echo "$chain"
}

fetch_from_gsm_chain() {
    local chain="$1"
    local token=""
    local selected_secret=""

    local IFS=','
    for candidate in $chain; do
        json_log "info" "secret_candidate_try" "Trying GSM secret candidate" "gsm" "$candidate"
        token=$(CLOUDSDK_CORE_DISABLE_PROMPTS=1 \
            gcloud --quiet secrets versions access latest \
                --secret="$candidate" \
                --project="$GSM_PROJECT" \
                2>/dev/null) || true

        if [[ -n "$token" ]]; then
            selected_secret="$candidate"
            echo "$selected_secret"$'\t'"$token"
            return 0
        fi
    done

    return 1
}

enforce_strict_if_needed() {
    local selected_source="$1"
    local selected_secret="$2"

    if ! is_truthy "$GIT_CREDENTIAL_GSM_STRICT"; then
        return 0
    fi

    if ! is_production_context; then
        return 0
    fi

    # In strict production mode, only canonical GSM secret is allowed.
    if [[ "$selected_source" != "gsm" || "$selected_secret" != "$CANONICAL_GSM_SECRET_NAME" ]]; then
        json_log "error" "strict_mode_block" "Strict mode blocked non-canonical credential source" "$selected_source" "$selected_secret"
        exit 1
    fi
}

# Only respond to github.com requests — pass all other hosts through
protocol=""
host=""
while IFS='=' read -r key value; do
    case "$key" in
        protocol) protocol="$value" ;;
        host)     host="$value" ;;
    esac
done < /dev/stdin

operation="${1:-}"

if [[ "$operation" == "get" ]]; then
    # Only handle github.com; let other helpers handle everything else
    if [[ "$host" != "$GITHUB_HOST" ]]; then
        exit 1
    fi

    chain=""
    token=""
    selected_source=""
    selected_secret=""

    chain="$(resolve_secret_chain)"
    json_log "info" "secret_chain_resolved" "Resolved deterministic secret fallback chain" "gsm" "$chain"

    if result="$(fetch_from_gsm_chain "$chain")"; then
        selected_secret="${result%%$'\t'*}"
        token="${result#*$'\t'}"
        selected_source="gsm"
        if [[ "$selected_secret" != "$CANONICAL_GSM_SECRET_NAME" ]]; then
            json_log "warn" "fallback_used" "Using legacy GSM secret candidate" "$selected_source" "$selected_secret"
        else
            json_log "info" "canonical_secret_selected" "Using canonical GSM secret" "$selected_source" "$selected_secret"
        fi
    else
        json_log "warn" "gsm_chain_exhausted" "No usable token found in GSM candidate chain" "gsm" "$chain"

        if is_truthy "$GIT_CREDENTIAL_GSM_ALLOW_ENV_FALLBACK"; then
            if [[ -n "${GH_TOKEN:-}" ]]; then
                token="$GH_TOKEN"
                selected_source="env"
                selected_secret="GH_TOKEN"
                json_log "warn" "fallback_used" "Using GH_TOKEN fallback" "$selected_source" "$selected_secret"
            elif [[ -n "${GITHUB_TOKEN:-}" ]]; then
                token="$GITHUB_TOKEN"
                selected_source="env"
                selected_secret="GITHUB_TOKEN"
                json_log "warn" "fallback_used" "Using GITHUB_TOKEN fallback" "$selected_source" "$selected_secret"
            fi
        fi
    fi

    if [[ -z "$token" ]]; then
        json_log "error" "credential_resolution_failed" "No credential source yielded a token" "none" "none"
        exit 1
    fi

    enforce_strict_if_needed "$selected_source" "$selected_secret"
    json_log "info" "credential_selected" "Credential source selected" "$selected_source" "$selected_secret"

    # Return credentials to git in the expected key=value format
    printf 'protocol=%s\nhost=%s\nusername=x-oauth-token\npassword=%s\n' \
        "${protocol:-https}" \
        "$GITHUB_HOST" \
        "$token"
fi

# store / erase: intentional no-op — GSM is the source of truth
# Returning 0 prevents git from prompting or writing ~/.git-credentials
exit 0

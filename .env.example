# ──── Domain & Network ────────────────────────────────────────────────────────
# Public domain for IDE and portals (required)
DOMAIN=ide.kushnir.cloud

# Workspace mount path (default: ./workspace)
WORKSPACE_PATH=./workspace

# ──── Google OAuth2 (for code-server via oauth2-proxy) ──────────────────────
# Obtain from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here

# ──── oauth2-proxy ─────────────────────────────────────────────────────────
# Generate: `python3 -c 'import secrets; print(secrets.token_urlsafe(32))'`
OAUTH2_PROXY_COOKIE_SECRET=your-cookie-secret-here

# ──── GoDaddy DNS-01 (for Caddy ACME challenge) ───────────────────────────
# Obtain from GoDaddy API portal (optional: use HTTP-01 if ports 80/443 open)
GODADDY_KEY=your-godaddy-api-key
GODADDY_SECRET=your-godaddy-api-secret

# ──── code-server ──────────────────────────────────────────────────────────
# Password for code-server access (change in production)
CODE_SERVER_PASSWORD=your-secure-password-here

# ──── GitHub Integration ───────────────────────────────────────────────────
# GitHub PAT for Copilot, extensions, Backstage catalog access
GITHUB_TOKEN=your-github-pat-here

# ──── RBAC API (JWT Authentication) ────────────────────────────────────────
# Base URL for OAuth2/OIDC endpoints (used by Appsmith and Backstage)
# In Docker: https://{DOMAIN}
# In development: http://localhost:3001
BASE_URL=https://ide.kushnir.cloud

# Generate: `openssl rand -base64 32`
JWT_SECRET=your-jwt-secret-here

# JWT token expiration (default: 24h)
JWT_EXPIRES_IN=24h

# ──── Ollama Configuration ─────────────────────────────────────────────────
# Number of CPU threads for Ollama inference
OLLAMA_NUM_THREAD=8

# GPU acceleration (0 = disabled, 1+ = enabled)
OLLAMA_NUM_GPU=0

# ──── Copilot Extensions ───────────────────────────────────────────────────
# GitHub Copilot extension version (pinned for reproducibility)
COPILOT_VERSION=1.299.0

# GitHub Copilot Chat extension version
COPILOT_CHAT_VERSION=0.27.2

# ──── Node.js Environment ─────────────────────────────────────────────────
# Set to 'production' for Caddy/RBAC deployments
NODE_ENV=production

# ──── Appsmith (Admin Portal) ──────────────────────────────────────────────
# Appsmith will be accessible at https://{DOMAIN}/appsmith
# Default credentials: admin@appsmith.com / appsmith
# Change JWT_SECRET above to secure the integration

# ──── Backstage (Developer Portal) ────────────────────────────────────────
# Backstage will be accessible at https://{DOMAIN}/backstage
# Requires GitHub token for catalog sync (use GITHUB_TOKEN above)
# Catalog items read from kushin77/code-server repository

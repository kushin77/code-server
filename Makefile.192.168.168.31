# Makefile for 192.168.168.31 On-Premises Deployment
# Purpose: Unified command interface for infrastructure deployment, validation, and operations
# Usage: make [target] [VAR=value]

.PHONY: help deploy validate health benchmark backup restore logs clean all-checks troubleshoot

# Configuration
HOST := 192.168.168.31
USER := akushnir
SSH_HOST := $(USER)@$(HOST)
DEPLOY_DIR := /home/akushnir/code-server-enterprise
TERRAFORM_DIR := terraform/$(HOST)
SCRIPTS_DIR := scripts
DOCS_DIR := docs
LOGS_DIR := logs

# Terraform variables
TF_VAR_file := $(TERRAFORM_DIR)/terraform.tfvars
TF_PLAN := $(TERRAFORM_DIR)/tfplan

# Color output
RED := \033[0;31m
GREEN := \033[0;32m
YELLOW := \033[1;33m
BLUE := \033[0;34m
NC := \033[0m

# Default target
help:
	@echo "$(BLUE)==== 192.168.168.31 Deployment Makefile ====$(NC)"
	@echo ""
	@echo "$(GREEN)Deployment Targets:$(NC)"
	@echo "  make deploy              - Deploy via remote Docker Compose on the primary host"
	@echo "  make deploy-gpu          - Deploy GPU infrastructure only"
	@echo "  make deploy-nas          - Deploy NAS mounts only"
	@echo "  make deploy-dry-run      - Dry-run remote compose deployment (no changes)"
	@echo ""
	@echo "$(GREEN)Validation & Inspection:$(NC)"
	@echo "  make validate            - Validate entire deployment"
	@echo "  make validate-gpu        - Validate GPU setup"
	@echo "  make validate-nas        - Validate NAS mounts"
	@echo "  make validate-network    - Validate network connectivity"
	@echo " make all-checks          - Run all validation checks"
	@echo ""
	@echo "$(GREEN)Health & Monitoring:$(NC)"
	@echo "  make health              - System health check"
	@echo "  make gpu-status          - GPU status and utilization"
	@echo "  make nas-status          - NAS mount status"
	@echo "  make monitor             - Real-time monitoring (GPU + NAS)"
	@echo "  make benchmark           - Performance benchmarking"
	@echo ""
	@echo "$(GREEN)Backup & Recovery:$(NC)"
	@echo "  make backup              - Trigger manual backup"
	@echo "  make backup-status       - Check backup status"
	@echo "  make restore             - Restore from backup (interactive)"
	@echo ""
	@echo "$(GREEN)Troubleshooting:$(NC)"
	@echo "  make troubleshoot        - Collect diagnostics"
	@echo "  make troubleshoot-gpu    - GPU troubleshooting"
	@echo "  make troubleshoot-nas    - NAS troubleshooting"
	@echo "  make logs                - View recent logs"
	@echo ""
	@echo "$(GREEN)Maintenance:$(NC)"
	@echo "  make clean               - Remove temporary files"
	@echo "  make clean-logs          - Clear old logs"
	@echo ""
	@echo "$(YELLOW)Options:$(NC)"
	@echo "  DRY_RUN=1               - Preview changes without applying"
	@echo "  VERBOSE=1               - Detailed output"
	@echo "  HOST=<ip>               - Target host (default: $(HOST))"
	@echo ""

# ============================================================================
# DEPLOYMENT TARGETS
# ============================================================================

.PHONY: deploy deploy-gpu deploy-nas deploy-infrastructure deploy-dry-run compose-deploy

deploy: validate-prerequisites deploy-infrastructure gpu-status nas-status all-checks
	@echo "$(GREEN)✓ Deployment completed successfully$(NC)"

deploy-infrastructure: compose-deploy
	@echo "$(GREEN)✓ Infrastructure deployment complete$(NC)"

compose-deploy:
	@echo "$(BLUE)→ Deploying via remote Docker Compose...$(NC)"
	@if [ -z "$(DRY_RUN)" ]; then \
		bash -lc 'set -euo pipefail; source scripts/_common/init.sh; assert_ssh_up; ssh_exec "cd $$DEPLOY_DIR && docker compose up -d --remove-orphans --pull always"'; \
	else \
		echo "$(BLUE)[DRY-RUN] Would run: ssh $(SSH_HOST) \"cd $(DEPLOY_DIR) && docker compose up -d --remove-orphans --pull always\"$(NC)"; \
	fi
	@echo "$(GREEN)✓ Remote compose deployment complete$(NC)"

deploy-gpu: validate-prerequisites terraform-plan-gpu terraform-apply
	@echo "$(GREEN)✓ GPU deployment complete$(NC)"
	@$(MAKE) -f $(lastword $(MAKEFILE_LIST)) validate-gpu

deploy-nas: validate-prerequisites nas-mount nas-backup-setup
	@echo "$(GREEN)✓ NAS deployment complete$(NC)"
	@$(MAKE) -f $(lastword $(MAKEFILE_LIST)) validate-nas

deploy-dry-run:
	@echo "$(BLUE)→ Running deployment in DRY-RUN mode (no changes)$(NC)"
	@DRY_RUN=1 $(MAKE) -f $(lastword $(MAKEFILE_LIST)) deploy-infrastructure

# ============================================================================
# TERRAFORM TARGETS
# ============================================================================

.PHONY: terraform-init terraform-plan terraform-plan-gpu terraform-apply terraform-output

terraform-init:
	@echo "$(BLUE)→ Initializing Terraform...$(NC)"
	cd $(TERRAFORM_DIR) && terraform init

terraform-plan: terraform-init
	@echo "$(BLUE)→ Planning infrastructure changes...$(NC)"
	cd $(TERRAFORM_DIR) && terraform plan -out=$(TF_PLAN) \
		-var-file="$(TF_VAR_file)"

terraform-plan-gpu: terraform-init
	@echo "$(BLUE)→ Planning GPU infrastructure...$(NC)"
	cd $(TERRAFORM_DIR) && terraform plan -out=$(TF_PLAN) \
		-var="skip_docker_setup=true" \
		-var="skip_nas_mount=true" \
		-var-file="$(TF_VAR_file)"

terraform-apply: terraform-plan
	@if [ -z "$(DRY_RUN)" ]; then \
		echo "$(YELLOW)→ Applying Terraform plan...$(NC)" && \
		cd $(TERRAFORM_DIR) && terraform apply -auto-approve $(TF_PLAN); \
	else \
		echo "$(BLUE)[DRY-RUN] Would apply: terraform apply $(TF_PLAN)$(NC)"; \
	fi

terraform-output:
	@echo "$(BLUE)→ Terraform Outputs:$(NC)"
	@cd $(TERRAFORM_DIR) && terraform output -no-color 2>/dev/null || echo "No outputs available"

terraform-destroy:
	@echo "$(RED)⚠ Destroying infrastructure - this cannot be undone!$(NC)"
	@read -p "Type 'yes' to confirm: " confirm; \
	if [ "$$confirm" = "yes" ]; then \
		cd $(TERRAFORM_DIR) && terraform destroy -auto-approve; \
	else \
		echo "Destroy cancelled"; \
	fi

# ============================================================================
# VALIDATION TARGETS
# ============================================================================

.PHONY: validate validate-gpu validate-nas validate-network validate-prerequisites all-checks

validate-prerequisites:
	@echo "$(BLUE)→ Checking prerequisites...$(NC)"
	@which ssh > /dev/null || { echo "$(RED)✗ SSH not available$(NC)"; exit 1; }
	@if [ -z "$(DRY_RUN)" ]; then \
		ssh -o BatchMode=yes -o StrictHostKeyChecking=no -o ConnectTimeout=5 $(SSH_HOST) "echo SSH_OK" >/dev/null 2>&1 || { echo "$(RED)✗ Cannot SSH to $(SSH_HOST)$(NC)"; exit 1; }; \
	else \
		echo "$(YELLOW)⚠ DRY-RUN skips live SSH connectivity check$(NC)"; \
	fi
	@echo "$(GREEN)✓ Prerequisites validated$(NC)"

validate: validate-gpu validate-nas validate-network
	@echo "$(GREEN)✓ Full validation passed$(NC)"

validate-gpu:
	@echo "$(BLUE)→ Validating GPU configuration...$(NC)"
	@$(SCRIPTS_DIR)/gpu-quickcheck-31.sh 2>/dev/null || echo "GPU validation requires host access"

validate-nas:
	@echo "$(BLUE)→ Validating NAS mounts...$(NC)"
	@ssh -o StrictHostKeyChecking=no $(SSH_HOST) "mountpoint -q /mnt/models && echo '$(GREEN)✓ /mnt/models mounted$(NC)' || echo '$(YELLOW)⚠ /mnt/models not mounted$(NC)'" 2>/dev/null || echo "NAS validation requires host access"

validate-network:
	@echo "$(BLUE)→ Validating network connectivity...$(NC)"
	@ping -c 1 -W 2 $(HOST) > /dev/null && echo "$(GREEN)✓ Host reachable$(NC)" || echo "$(RED)✗ Host unreachable$(NC)"
	@ping -c 1 -W 2 192.168.168.10 > /dev/null && echo "$(GREEN)✓ Primary NAS reachable$(NC)" || echo "$(YELLOW)⚠ Primary NAS unreachable$(NC)"

all-checks: validate-prerequisites validate-gpu validate-nas validate-network
	@echo "$(GREEN)✓ All validation checks passed$(NC)"

# ============================================================================
# NAS TARGETS
# ============================================================================

.PHONY: nas-mount nas-unmount nas-backup-setup nas-validate

nas-mount:
	@echo "$(BLUE)→ Mounting NAS storage...$(NC)"
	@if [ -z "$(DRY_RUN)" ]; then \
		ssh -o StrictHostKeyChecking=no $(SSH_HOST) "sudo bash -s" < $(SCRIPTS_DIR)/nas-mount-31.sh mount; \
	else \
		echo "$(BLUE)[DRY-RUN] Would mount NAS shares$(NC)"; \
	fi

nas-unmount:
	@echo "$(YELLOW)→ Unmounting NAS storage...$(NC)"
	@ssh $(SSH_HOST) "sudo umount -f /mnt/models /mnt/data /mnt/backups" 2>/dev/null || true
	@echo "$(GREEN)✓ NAS unmounted$(NC)"

nas-backup-setup:
	@echo "$(BLUE)→ Setting up backup automation...$(NC)"
	@ssh $(SSH_HOST) "$(SCRIPTS_DIR)/nas-mount-31.sh backup"

nas-validate:
	@echo "$(BLUE)→ Validating NAS configuration...$(NC)"
	@ssh $(SSH_HOST) "$(SCRIPTS_DIR)/nas-mount-31.sh validate"

# ============================================================================
# STATUS & MONITORING TARGETS
# ============================================================================

.PHONY: health gpu-status nas-status monitor benchmark

health: all-checks
	@echo ""
	@echo "$(GREEN)==== System Health ====$(NC)"
	@echo ""
	@ssh $(SSH_HOST) "uname -a"
	@echo ""
	@echo "$(GREEN)Disk Space:$(NC)"
	@ssh $(SSH_HOST) "df -h / /mnt/models /mnt/data 2>/dev/null | awk 'NR==1 || !/^Filesystem/ {print}'"
	@echo ""
	@echo "$(GREEN)Memory:$(NC)"
	@ssh $(SSH_HOST) "free -h | awk 'NR==1 || /^Mem/ {print}'"
	@echo ""

gpu-status:
	@echo "$(BLUE)→ GPU Status:$(NC)"
	@ssh $(SSH_HOST) "nvidia-smi --query-gpu=index,name,utilization.gpu,memory.used,memory.total,temperature.gpu,power.draw --format=table,noheader 2>/dev/null" || echo "GPU tools not available"

nas-status:
	@echo "$(BLUE)→ NAS Mount Status:$(NC)"
	@ssh $(SSH_HOST) "mount | grep -i nfs || echo 'No NFS mounts'"
	@echo ""
	@echo "$(BLUE)→ NAS Capacity:$(NC)"
	@ssh $(SSH_HOST) "df -h /mnt/models /mnt/data /mnt/backups 2>/dev/null || echo 'NAS not mounted'"

monitor:
	@echo "$(BLUE)→ Starting real-time monitoring (GPU + NAS)...$(NC)"
	@echo "Press Ctrl+C to exit"
	@watch -n 2 "ssh $(SSH_HOST) 'clear; echo \"GPU Status:\"; nvidia-smi --query-gpu=index,name,utilization.gpu,memory.used --format=csv,noheader 2>/dev/null; echo \"\"; echo \"NAS Status:\"; df -h /mnt/models 2>/dev/null; echo \"\"; echo \"System Health:\"; free -h | grep Mem'"

benchmark:
	@echo "$(BLUE)→ Running performance benchmarks...$(NC)"
	@echo ""
	@echo "$(GREEN)GPU Benchmark:$(NC)"
	@ssh $(SSH_HOST) "nvidia-smi dmon -c 1" 2>/dev/null || echo "GPU benchmarking not available"
	@echo ""
	@echo "$(GREEN)NAS Throughput:$(NC)"
	@ssh $(SSH_HOST) "sudo dd if=/mnt/models of=/dev/null bs=1M count=100 2>&1 | tail -1" 2>/dev/null || echo "NAS benchmarking not available"

# ============================================================================
# BACKUP & RECOVERY TARGETS
# ============================================================================

.PHONY: backup backup-status restore

backup:
	@echo "$(BLUE)→ Triggering manual backup...$(NC)"
	@ssh $(SSH_HOST) "/usr/local/bin/backup-models.sh" 2>/dev/null || echo "Backup script not available"
	@echo "$(GREEN)✓ Backup triggered$(NC)"

backup-status:
	@echo "$(BLUE)→ Backup Status:$(NC)"
	@ssh $(SSH_HOST) "tail -20 /var/log/nas-backup.log 2>/dev/null || echo 'No backup logs'"

restore:
	@echo "$(RED)⚠ Restore from backup - interactive mode$(NC)"
	@echo "Available backups:"
	@ssh $(SSH_HOST) "ls -lh /mnt/backups/full-backup-*.tar.gz 2>/dev/null | tail -5"
	@read -p "Enter backup file to restore (or press Enter to cancel): " backup_file; \
	if [ -n "$$backup_file" ]; then \
		ssh $(SSH_HOST) "sudo tar -xzf $$backup_file -C /"; \
		echo "$(GREEN)✓ Restore completed$(NC)"; \
	fi

# ============================================================================
# TROUBLESHOOTING & LOGS
# ============================================================================

.PHONY: troubleshoot troubleshoot-gpu troubleshoot-nas logs logs-clear

troubleshoot: troubleshoot-gpu troubleshoot-nas
	@echo "$(GREEN)✓ Diagnostic data collected$(NC)"

troubleshoot-gpu:
	@echo "$(BLUE)→ GPU Troubleshooting:$(NC)"
	@ssh $(SSH_HOST) "nvidia-smi -q 2>/dev/null | head -30 || echo 'GPU info not available'"

troubleshoot-nas:
	@echo "$(BLUE)→ NAS Troubleshooting:$(NC)"
	@ssh $(SSH_HOST) "$(SCRIPTS_DIR)/nas-mount-31.sh troubleshoot" 2>/dev/null || echo "NAS troubleshooting not available"

logs:
	@echo "$(BLUE)→ Recent System Logs:$(NC)"
	@ssh $(SSH_HOST) "sudo journalctl -n 30 --no-pager -p err..alert 2>/dev/null || dmesg | tail -30"

logs-clear:
	@echo "$(YELLOW)→ Clearing old logs...$(NC)"
	@ssh $(SSH_HOST) "sudo find /var/log -name '*.log*' -mtime +30 -delete" 2>/dev/null || true
	@echo "$(GREEN)✓ Log cleanup complete$(NC)"

# ============================================================================
# CLEANUP & MAINTENANCE
# ============================================================================

.PHONY: clean clean-logs clean-terraform

clean: clean-logs clean-terraform
	@echo "$(GREEN)✓ Cleanup complete$(NC)"

clean-logs:
	@echo "$(BLUE)→ Clearing temporary logs...$(NC)"
	@rm -rf $(LOGS_DIR)/*.log 2>/dev/null || true
	@echo "$(GREEN)✓ Logs cleared$(NC)"

clean-terraform:
	@echo "$(BLUE)→ Cleaning Terraform state...$(NC)"
	@cd $(TERRAFORM_DIR) && rm -f $(TF_PLAN) .terraform.lock.hcl 2>/dev/null || true
	@echo "$(GREEN)✓ Terraform cleaned$(NC)"

# ============================================================================
# QUICK OPERATIONS
# ============================================================================

# Quick deploy (validate -> deploy -> verify)
quick-deploy: all-checks deploy validate
	@echo "$(GREEN)✓ Quick deploy successful$(NC)"

# Quick health check (all validation in one command)
quick-check: all-checks health
	@echo "$(GREEN)✓ System health verified$(NC)"

# Production preflight (all validations + benchmarks)
preflight: all-checks health benchmark
	@echo "$(GREEN)✓ Preflight check passed - ready for production$(NC)"

# ============================================================================
# INFORMATION TARGETS
# ============================================================================

.PHONY: version info docs

version:
	@echo "$(BLUE)Deployment Suite Version:$(NC)"
	@cat $(DOCS_DIR)/DEPLOYMENT.md | grep -i version | head -1 || echo "Version info not available"

info:
	@echo "$(BLUE)==== Deployment Information ====$(NC)"
	@echo "Host: $(HOST)"
	@echo "User: $(USER)"
	@echo "Terraform Directory: $(TERRAFORM_DIR)"
	@echo "Scripts Directory: $(SCRIPTS_DIR)"
	@echo "Documentation: $(DOCS_DIR)"
	@echo ""
	@echo "Available documentation:"
	@ls -1 $(DOCS_DIR)/*31*.md 2>/dev/null | sed 's/^/  - /'

docs:
	@echo "$(BLUE)==== Documentation ====$(NC)"
	@echo "1. GPU Configuration:"
	@echo "   $(DOCS_DIR)/GPU_TROUBLESHOOTING_GUIDE.md"
	@echo "   $(DOCS_DIR)/CUDA_VALIDATION_PROCEDURES.md"
	@echo ""
	@echo "2. NAS Integration:"
	@echo "   $(DOCS_DIR)/NAS_INTEGRATION_SPECIFICATION.md"
	@echo "   $(DOCS_DIR)/NAS_TROUBLESHOOTING_GUIDE.md"
	@echo ""
	@echo "3. Infrastructure:"
	@echo "   $(DOCS_DIR)/192.168.168.31-host-spec.md"
	@echo "   $(DOCS_DIR)/network-topology-31.md"
	@echo "   $(DOCS_DIR)/nas-specification-31.md"

# ============================================================================
# PHONY TARGETS (ensure these run regardless of file state)
# ============================================================================

.PHONY: all all-targets version info docs quick-deploy quick-check preflight

# Default: show help
.DEFAULT_GOAL := help

{
  "name": "code-server-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.15.4 <10"
  },
  "scripts": {
    "bootstrap": "pnpm install --frozen-lockfile",
    "install:workspace": "pnpm install",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "type-check": "pnpm -r --if-present type-check",
    "ci:lockfile": "pnpm install --frozen-lockfile --ignore-scripts",
    "validate:lockfile": "bash scripts/ci/check-pnpm-lockfile.sh",
    "validate:monorepo": "bash scripts/ci/validate-monorepo-target.sh",
    "validate:issues": "python3 scripts/ops/issue_execution_manifest.py validate",
    "issues:queue": "python3 scripts/ops/issue_execution_manifest.py queue",
    "redeploy:portal-oauth": "bash scripts/deploy/redeploy-portal-oauth-routing.sh",
    "redeploy:portal-oauth:dry-run": "bash scripts/deploy/redeploy-portal-oauth-routing.sh --dry-run"
  }
}

# RCA Engine container — root cause analysis from alerts
FROM python:3.11-slim

WORKDIR /app

# Install required Python packages
RUN pip install --no-cache-dir requests prometheus-client pyyaml

# Copy RCA engine script
COPY scripts/observability/rca-engine.py .

# Run RCA engine in daemon mode
ENTRYPOINT ["python", "rca-engine.py", "--daemon"]

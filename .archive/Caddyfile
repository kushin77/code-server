# Caddyfile — CONSOLIDATED ON-PREMISES CONFIGURATION (IaC-READY)
#
# Semantic configuration focused on 192.168.168.31
# HTTP-only with nip.io (no ambiguous site definitions)
# ════════════════════════════════════════════════════════════════════════════

{
    log default {
        format json
        output stdout
    }

    # Global email (not used for HTTP-only mode)
    email admin@kushnir.cloud

    # ACME disabled for on-prem
    acme_ca https://acme-v02.api.letsencrypt.org/directory

    # HTTP-only for on-prem
    auto_https off
}

# ─ Code-Server IDE ─
http://code-server.192.168.168.31.nip.io {
    encode gzip
    header X-Content-Type-Options nosniff
    header X-Frame-Options DENY
    header Referrer-Policy strict-origin-when-cross-origin
    reverse_proxy code-server:8080 {
        flush_interval -1
    }
}

# ─ Grafana Dashboard ─
http://grafana.192.168.168.31.nip.io {
    encode gzip
    reverse_proxy grafana:3000 {
        flush_interval -1
    }
}

# ─ Prometheus Metrics ─
http://prometheus.192.168.168.31.nip.io {
    encode gzip
    reverse_proxy prometheus:9090 {
        flush_interval -1
    }
}

# ─ Jaeger Distributed Tracing ─
http://jaeger.192.168.168.31.nip.io {
    encode gzip
    reverse_proxy jaeger:16686 {
        flush_interval -1
    }
}

# ─ Alert Manager ─
http://alertmanager.192.168.168.31.nip.io {
    encode gzip
    reverse_proxy alertmanager:9093 {
        flush_interval -1
    }
}

# ─ Health Check ─
http://health.192.168.168.31.nip.io {
    respond "OK" 200
}


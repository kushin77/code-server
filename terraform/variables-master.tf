################################################################################\n# terraform/variables.tf - Master Environment & Configuration Variables\n# Purpose: Single source of truth for all Terraform input variables\n# Status: Production-ready\n################################################################################\n\n### ─── DEPLOYMENT & INFRASTRUCTURE ────────────────────────────────────────────\n\nvariable \"deployment_host\" {\n  description = \"Primary production deployment host IP\"\n  type        = string\n  default     = \"192.168.168.31\"\n}\n\nvariable \"standby_host\" {\n  description = \"Standby/failover host IP\"\n  type        = string\n  default     = \"192.168.168.30\"\n}\n\nvariable \"nas_host\" {\n  description = \"Network-attached storage host IP\"\n  type        = string\n  default     = \"192.168.168.56\"\n}\n\nvariable \"nas_mount_path\" {\n  description = \"NAS mount path on deployment hosts\"\n  type        = string\n  default     = \"/exports\"\n}\n\nvariable \"environment\" {\n  description = \"Deployment environment (development, staging, production)\"\n  type        = string\n  default     = \"production\"\n  \n  validation {\n    condition     = contains([\"development\", \"staging\", \"production\"], var.environment)\n    error_message = \"Environment must be one of: development, staging, production.\"\n  }\n}\n\nvariable \"timezone\" {\n  description = \"Timezone for all services\"\n  type        = string\n  default     = \"UTC\"\n}\n\n### ─── CONTAINER IMAGE VERSIONS (Immutable Pinning) ───────────────────────────\n\nvariable \"container_images\" {\n  description = \"Pinned container image versions (never use :latest tag)\"\n  type        = map(string)\n  \n  default = {\n    code_server           = \"codercom/code-server:4.115.0\"\n    oauth2_proxy          = \"quay.io/oauth2-proxy/oauth2-proxy:v7.5.1\"\n    caddy                 = \"caddy:2.7.6-alpine\"\n    postgres              = \"postgres:15.2-alpine\"\n    redis                 = \"redis:7.0-alpine\"\n    prometheus            = \"prom/prometheus:v2.48.0\"\n    grafana               = \"grafana/grafana:10.2.3\"\n    alertmanager          = \"prom/alertmanager:v0.26.0\"\n    jaeger                = \"jaegertracing/all-in-one:1.50.0\"\n    loki                  = \"grafana/loki:2.9.7\"\n    promtail              = \"grafana/promtail:2.9.7\"\n  }\n}\n\n### ─── RESOURCE LIMITS & RESERVATIONS ──────────────────────────────────────────\n\nvariable \"resource_limits\" {\n  description = \"Container resource limits and reservations\"\n  type = map(object({\n    memory_limit      = string\n    memory_reservation = string\n    cpu_limit         = string\n    cpu_reservation   = string\n  }))\n  \n  default = {\n    code_server = {\n      memory_limit       = \"4g\"\n      memory_reservation = \"512m\"\n      cpu_limit          = \"2.0\"\n      cpu_reservation    = \"0.5\"\n    }\n    postgres = {\n      memory_limit       = \"2g\"\n      memory_reservation = \"256m\"\n      cpu_limit          = \"1.0\"\n      cpu_reservation    = \"0.25\"\n    }\n    redis = {\n      memory_limit       = \"768m\"\n      memory_reservation = \"64m\"\n      cpu_limit          = \"0.5\"\n      cpu_reservation    = \"0.1\"\n    }\n    prometheus = {\n      memory_limit       = \"1g\"\n      memory_reservation = \"128m\"\n      cpu_limit          = \"1.0\"\n      cpu_reservation    = \"0.25\"\n    }\n    grafana = {\n      memory_limit       = \"512m\"\n      memory_reservation = \"64m\"\n      cpu_limit          = \"0.5\"\n      cpu_reservation    = \"0.1\"\n    }\n  }\n}\n\n### ─── HEALTH CHECK CONFIGURATION ───────────────────────────────────────────────\n\nvariable \"health_check_config\" {\n  description = \"Global health check configuration for all services\"\n  type = object({\n    start_period_seconds = number\n    interval_seconds     = number\n    timeout_seconds      = number\n    retries              = number\n  })\n  \n  default = {\n    start_period_seconds = 40\n    interval_seconds     = 30\n    timeout_seconds      = 10\n    retries              = 3\n  }\n}\n\n### ─── DATABASE CONFIGURATION ────────────────────────────────────────────────────\n\nvariable \"database\" {\n  description = \"PostgreSQL database configuration\"\n  type = object({\n    host                = string\n    port                = number\n    name                = string\n    user                = string\n    pool_min_size       = number\n    pool_max_size       = number\n    pool_idle_timeout   = number # milliseconds\n    ssl_mode            = string\n  })\n  \n  default = {\n    host              = \"postgres\"\n    port              = 5432\n    name              = \"code_server\"\n    user              = \"codeserver\"\n    pool_min_size     = 5\n    pool_max_size     = 20\n    pool_idle_timeout = 30000\n    ssl_mode          = \"require\"\n  }\n}\n\n### ─── CACHE CONFIGURATION (Redis) ───────────────────────────────────────────────\n\nvariable \"redis\" {\n  description = \"Redis cache configuration\"\n  type = object({\n    host     = string\n    port     = number\n    db       = number\n    ttl      = number # seconds\n  })\n  \n  default = {\n    host = \"redis\"\n    port = 6379\n    db   = 0\n    ttl  = 3600\n  }\n}\n\n### ─── AUTHENTICATION & OAUTH2 ───────────────────────────────────────────────────\n\nvariable \"oauth2\" {\n  description = \"OAuth2 proxy configuration\"\n  type = object({\n    enabled           = bool\n    client_id         = string # From GSM secret\n    client_secret     = string # From GSM secret\n    redirect_uri      = string\n    authorize_url     = string\n    token_url         = string\n    user_info_url     = string\n    scope             = string\n    cookie_secure     = bool\n    cookie_httponly   = bool\n    cookie_samesite   = string\n  })\n  \n  default = {\n    enabled        = true\n    client_id      = \"\"  # Must be set via -var or GSM\n    client_secret  = \"\"  # Must be set via -var or GSM\n    redirect_uri   = \"https://code-server.example.com/auth/callback\"\n    authorize_url  = \"https://accounts.google.com/o/oauth2/v2/auth\"\n    token_url      = \"https://oauth2.googleapis.com/token\"\n    user_info_url  = \"https://openidconnect.googleapis.com/v1/userinfo\"\n    scope          = \"openid email profile\"\n    cookie_secure  = true\n    cookie_httponly = true\n    cookie_samesite = \"Strict\"\n  }\n}\n\n### ─── SECURITY & SECRETS ────────────────────────────────────────────────────────\n\nvariable \"secrets\" {\n  description = \"Security secrets (all from Google Secret Manager)\"\n  type = object({\n    jwt_secret              = string\n    encryption_key          = string\n    request_signing_key     = string\n    audit_log_secret        = string\n    csrf_token_secret       = string\n  })\n  \n  sensitive = true\n  \n  default = {\n    jwt_secret          = \"\"  # Must be injected from GSM\n    encryption_key      = \"\"  # Must be injected from GSM\n    request_signing_key = \"\"  # Must be injected from GSM\n    audit_log_secret    = \"\"  # Must be injected from GSM\n    csrf_token_secret   = \"\"  # Must be injected from GSM\n  }\n}\n\n### ─── GPU CONFIGURATION ─────────────────────────────────────────────────────────\n\nvariable \"gpu\" {\n  description = \"GPU configuration for Ollama and ML workloads\"\n  type = object({\n    enabled             = bool\n    device_id           = number\n    num_gpu             = number\n    max_memory          = string\n    tf_force_gpu_growth = bool\n  })\n  \n  default = {\n    enabled             = true\n    device_id           = 1\n    num_gpu             = 1\n    max_memory          = \"8g\"\n    tf_force_gpu_growth = true\n  }\n}\n\n### ─── NAS BACKUP CONFIGURATION ──────────────────────────────────────────────────\n\nvariable \"nas_backup\" {\n  description = \"NAS backup and persistence configuration\"\n  type = object({\n    enabled           = bool\n    interval_seconds  = number\n    mount_options     = string\n    retention_days    = number\n    backup_paths      = list(string)\n  })\n  \n  default = {\n    enabled          = true\n    interval_seconds = 3600  # 1 hour\n    mount_options    = \"soft,timeo=100,retrans=3,noresvport\"\n    retention_days   = 30\n    backup_paths = [\n      \"/var/lib/postgresql\",\n      \"/var/lib/redis\",\n      \"/workspace\",\n      \"/etc/code-server\"\n    ]\n  }\n}\n\n### ─── VPN CONFIGURATION ─────────────────────────────────────────────────────────\n\nvariable \"vpn\" {\n  description = \"VPN endpoint and networking configuration\"\n  type = object({\n    gateway_ip   = string\n    endpoint_port = number\n    protocol     = string\n    cipher       = string\n    tls_auth_key = string # From GSM secret\n  })\n  \n  sensitive = true\n  \n  default = {\n    gateway_ip    = \"192.168.168.1\"\n    endpoint_port = 1194\n    protocol      = \"udp\"\n    cipher        = \"AES-256-GCM\"\n    tls_auth_key  = \"\"  # Must be injected from GSM\n  }\n}\n\n### ─── OBSERVABILITY & MONITORING ───────────────────────────────────────────────\n\nvariable \"observability\" {\n  description = \"Prometheus, Grafana, AlertManager, Jaeger configuration\"\n  type = object({\n    prometheus_port    = number\n    grafana_port       = number\n    alertmanager_port  = number\n    jaeger_agent_host  = string\n    jaeger_agent_port  = number\n    log_level          = string  # debug, info, warn, error\n    enable_tracing     = bool\n    enable_metrics     = bool\n  })\n  \n  default = {\n    prometheus_port   = 9090\n    grafana_port      = 3000\n    alertmanager_port = 9093\n    jaeger_agent_host = \"localhost\"\n    jaeger_agent_port = 6831\n    log_level         = \"info\"\n    enable_tracing    = true\n    enable_metrics    = true\n  }\n}\n\n### ─── FEATURE FLAGS & DEPLOYMENT ───────────────────────────────────────────────\n\nvariable \"feature_flags\" {\n  description = \"Feature flags for gradual rollout and experimentation\"\n  type = map(object({\n    enabled = bool\n    rollout_percentage = number  # 1-100\n  }))\n  \n  default = {\n    readonly_ide = {\n      enabled            = true\n      rollout_percentage = 100\n    }\n    git_proxy = {\n      enabled            = true\n      rollout_percentage = 100\n    }\n    database_optimization = {\n      enabled            = true\n      rollout_percentage = 100\n    }\n    canary_deployment = {\n      enabled            = true\n      rollout_percentage = 1  # Start at 1%, increase gradually\n    }\n    circuit_breaker = {\n      enabled            = true\n      rollout_percentage = 100\n    }\n  }\n}\n\n### ─── RATE LIMITING ─────────────────────────────────────────────────────────────\n\nvariable \"rate_limiting\" {\n  description = \"API rate limiting configuration\"\n  type = object({\n    window_ms      = number\n    max_requests   = number\n    by_ip          = bool\n    exclude_paths  = list(string)\n  })\n  \n  default = {\n    window_ms     = 60000  # 1 minute\n    max_requests  = 100\n    by_ip         = true\n    exclude_paths = [\"/health\", \"/metrics\", \"/readiness\"]\n  }\n}\n\n### ─── TAGS & LABELS ────────────────────────────────────────────────────────────\n\nvariable \"common_tags\" {\n  description = \"Common tags applied to all resources\"\n  type        = map(string)\n  \n  default = {\n    Environment  = \"production\"\n    Project      = \"code-server-enterprise\"\n    ManagedBy    = \"terraform\"\n    CreatedDate  = \"2026-04-15\"\n    CostCenter   = \"engineering\"\n    Owner        = \"devops\"\n  }\n}\n\nvariable \"labels\" {\n  description = \"Kubernetes-style labels for container metadata\"\n  type        = map(map(string))\n  \n  default = {\n    code-server = {\n      app     = \"code-server\"\n      version = \"4.115.0\"\n      tier    = \"application\"\n    }\n    postgres = {\n      app     = \"postgres\"\n      version = \"15.2\"\n      tier    = \"database\"\n    }\n    redis = {\n      app     = \"redis\"\n      version = \"7.0\"\n      tier    = \"cache\"\n    }\n  }\n}\n"
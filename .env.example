# ═══════════════════════════════════════════════════════════════════════════════
# .env.example — code-server-enterprise
# Copy to .env and fill in values.  NEVER commit .env to git.
# Secrets should be stored in Google Secret Manager (see scripts/lib/secrets.sh)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Domain & TLS ─────────────────────────────────────────────────────────────
DOMAIN=ide.kushnir.cloud
ACME_EMAIL=ops@kushnir.cloud

# ── code-server ───────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 16
CODE_SERVER_PASSWORD=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=codeserver
POSTGRES_USER=codeserver
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 24
REDIS_PASSWORD=

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
# Generate: openssl rand -hex 16
GRAFANA_ADMIN_PASSWORD=

# ── oauth2-proxy ──────────────────────────────────────────────────────────────
# Cookie secret MUST be exactly 16 bytes (32 hex chars)
# Generate: openssl rand -hex 16
OAUTH2_PROXY_COOKIE_SECRET=

# ── Google OAuth (create at: console.cloud.google.com → APIs → Credentials) ──
# For on-prem testing set GOOGLE_CLIENT_ID to any placeholder
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub (optional — for Copilot in code-server) ───────────────────────────
GITHUB_TOKEN=

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_NUM_THREAD=8

# ── GSM (optional — leave blank for .env fallback) ───────────────────────────
# SECRET_PROJECT=my-gcp-project-id
# GSM_PREFIX=code-server-enterprise

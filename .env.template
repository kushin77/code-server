# .env.template — copy to .env and populate
# Auto-populated by: ./scripts/deploy-kushnir-cloud.sh  (fetches from GSM)
# Manual:           cp .env.template .env && nano .env
# NEVER commit .env

# Target domain — change this to move the stack to a different domain
DOMAIN=ide.kushnir.cloud

# Workspace directory mounted into code-server at /home/coder/workspace
# Use an absolute path to keep data outside the repo, or leave as ./workspace
WORKSPACE_PATH=./workspace

# Google OAuth2 credentials (from GSM: prod/portal/google-client-id)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# oauth2-proxy cookie encryption (auto-generated by deploy script if blank)
OAUTH2_PROXY_COOKIE_SECRET=

# code-server password (auto-generated by deploy script if blank)
CODE_SERVER_PASSWORD=

# GitHub PAT — pre-authenticates Copilot inside the IDE so you don't see a second login prompt.
# Without this, the IDE triggers a GitHub OAuth flow that can conflict with the Google SSO layer.
# Create at: https://github.com/settings/tokens/new  (Classic PAT)
# Minimum scopes: read:user, user:email
# Copilot access is tied to your GitHub subscription, not a PAT scope — no extra scope needed.
GITHUB_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# AGENT FARM — LangGraph + MCP + RAG stack
# ─────────────────────────────────────────────────────────────────────────────

# Ollama models used by the agent farm
# Must match a name registered in Ollama (run: make pull-recommended)
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:14b-instruct-q6_K
OLLAMA_FAST_MODEL=qwen2.5-coder:7b-instruct-q8_0

# HuggingFace token for downloading gated GGUF models (hf_pull_model.sh)
HF_TOKEN=

# Sentence-transformers model used by the embeddings service
EMBED_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5

# Keycloak database (auto-created, keep consistent between .env recreations)
KEYCLOAK_DB_PASSWORD=

# Keycloak admin console credentials
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=

# OAuth2 client secret for the agent-api service account in Keycloak
AGENT_API_CLIENT_SECRET=

# OAuth2 client secret for Backstage service account
BACKSTAGE_KEYCLOAK_SECRET=

# Agent execution controls
AGENT_MAX_ITERATIONS=10
# Set to "true" to require HITL approval for all executor actions (recommended: prod=true)
HITL_STRICT=false
# Set to "true" to disable JWT validation for local development
DEV_MODE=false

# SMTP for Keycloak email (optional — org-level alerting)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

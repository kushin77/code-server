*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
.DS_Store

# Local temporary files
*.tmp
*.bak
*.backup

# Sensitive data (if accidentally created)
*.pem
*.key
.env
.env.local

# User session and secrets (never commit)
sessions/
.secrets/

# SOPS/age secrets — plaintext variants blocked
# Only *.enc.yaml and *.enc.env (encrypted) may be committed
secrets/*.yaml
secrets/*.env
!secrets/*.enc.yaml
!secrets/*.enc.env
!secrets/*.yaml.template
!secrets/*.env.template
!secrets/README.md

# Docker
docker-compose.override.yml

# Caddy
*.crt
*.key

# Build artifacts
node_modules/
dist/
build/
*.d.ts
*.d.ts.map
*.js.map

# Terraform backup
backup.tfstate

workspace/*
!workspace/.gitkeep
terraform.tfvars
data/postgresql/
data/

# One-time ad-hoc admin scripts (not source-controlled)
fix_gpu.py
fix_*.py
patch_*.py

# Binary packages (do not commit)
archived/*.deb
archived/*.rpm
archived/*.tar.gz

# Archived phase scripts (historical reference, not active IaC)
archived/scripts/

# Environment-specific configs generated at deploy time
config/environment/

# Old deployment status docs (phase-specific, historical only)
docs/archived/

# ════════════════════════════════════════════════════════════════════════════════════════════
# .env.defaults — Default Environment Variables
# ════════════════════════════════════════════════════════════════════════════════════════════
#
# This file contains all default values for environment variables.
# It is loaded first, then overridden by environment-specific files (.env.production, etc.)
#
# Source of Truth: .env.schema.json
# Loading Order:
#   1. .env.defaults (this file — lowest priority)
#   2. .env.${DEPLOYMENT_ENV} (environment overrides)
#   3. ${HOME}/.code-server/.env (user local, not tracked)
#   4. Vault secrets (highest priority, runtime only)
#
# Generated: 2026-04-16 (from .env.schema.json)
# ════════════════════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────────────────
# [INFRASTRUCTURE] Core deployment configuration
# ─────────────────────────────────────────────────────────────────────────────────────────────

# Deployment environment (dev, staging, production, onprem)
DEPLOYMENT_ENV=dev

# Root domain for all services (used by Caddyfile, DNS, TLS certificates)
APEX_DOMAIN=localhost

# Primary production host IP (where Docker runs)
PRIMARY_HOST_IP=127.0.0.1

# Failover/replica host IP (optional)
STANDBY_HOST_IP=127.0.0.1

# SSH port for deployment host
SSH_PORT=22

# Docker daemon socket (local or remote SSH)
DOCKER_SOCKET=unix:///var/run/docker.sock

# ─────────────────────────────────────────────────────────────────────────────────────────────
# [AUTHENTICATION] OAuth2, OIDC, user authentication
# ─────────────────────────────────────────────────────────────────────────────────────────────

# ⚠️  SECRET: Google OAuth2 Client ID (from Google Cloud Console)
# Store in Vault for production! Do NOT commit real values to git.
GOOGLE_CLIENT_ID=YOUR-CLIENT-ID.apps.googleusercontent.com

# ⚠️  SECRET: Google OAuth2 Client Secret
# Generate via: vault kv get secret/oauth2/google/client_secret (production)
GOOGLE_CLIENT_SECRET=YOUR-CLIENT-SECRET-HERE

# OAuth2 callback URL (legacy global fallback; prefer per-surface URLs below)
OAUTH2_REDIRECT_URL=http://localhost:8080/oauth2/callback

# Optional overrides for separate IDE/portal OAuth apps.
# If unset, services fall back to GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET.
OAUTH2_IDE_GOOGLE_CLIENT_ID=
OAUTH2_IDE_GOOGLE_CLIENT_SECRET=
OAUTH2_PORTAL_GOOGLE_CLIENT_ID=
OAUTH2_PORTAL_GOOGLE_CLIENT_SECRET=

# Surface-specific callback URLs (must match Google Cloud Console redirect URIs)
OAUTH2_PROXY_IDE_REDIRECT_URL=https://ide.kushnir.cloud/oauth2/callback
OAUTH2_PROXY_PORTAL_REDIRECT_URL=https://kushnir.cloud/oauth2/callback

# Optional domain filters. Keep * to avoid Google org_internal 403 before the allowlist file is checked.
OAUTH2_PROXY_IDE_EMAIL_DOMAINS=*
OAUTH2_PROXY_PORTAL_EMAIL_DOMAINS=*

# ⚠️  SECRET: oauth2-proxy cookie encryption key (32 hex chars = 16 bytes AES)
# Generate via: openssl rand -hex 16
# Example: 0123456789abcdef0123456789abcdef
OAUTH2_PROXY_COOKIE_SECRET=0123456789abcdef0123456789abcdef

# ⚠️  SECRET: GitHub personal access token (optional, for CI/CD)
GITHUB_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────────────────────
# [DATABASE] PostgreSQL and data stores
# ─────────────────────────────────────────────────────────────────────────────────────────────

# PostgreSQL hostname (Docker service name or network host)
POSTGRES_HOST=postgres

# PostgreSQL port
POSTGRES_PORT=5432

# Database name
POSTGRES_DB=code_server

# PostgreSQL user
POSTGRES_USER=postgres

# ⚠️  SECRET: PostgreSQL password
POSTGRES_PASSWORD=postgres

# Redis hostname
REDIS_HOST=redis

# Redis port
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────────────────────
# [SECURITY] Encryption, TLS, certificates
# ─────────────────────────────────────────────────────────────────────────────────────────────

# TLS certificate file (auto-generated by Let's Encrypt if not provided)
TLS_CERT_FILE=

# TLS private key file (auto-generated by Let's Encrypt if not provided)
TLS_KEY_FILE=

# ⚠️  SECRET: SOPS age key file (development only, not for production)
SOPS_AGE_KEY_FILE=

# Enable SOPS secret encryption (false by default)
SOPS_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────────────────────
# [OBSERVABILITY] Logging, metrics, tracing
# ─────────────────────────────────────────────────────────────────────────────────────────────

# Global log level (debug, info, warn, error)
LOG_LEVEL=info

# Prometheus metrics port
PROMETHEUS_PORT=9090

# Grafana dashboard port
GRAFANA_PORT=3000

# Enable distributed tracing (Jaeger)
JAEGER_ENABLED=false

# Jaeger UI endpoint
JAEGER_ENDPOINT=http://localhost:16686

# Loki log aggregation host
LOKI_HOST=loki

# Loki port
LOKI_PORT=3100

# ─────────────────────────────────────────────────────────────────────────────────────────────
# [SERVICES] Service-specific configuration
# ─────────────────────────────────────────────────────────────────────────────────────────────

# Code-server application port (internal, behind OAuth2 proxy)
CODE_SERVER_PORT=8080

# Code-server bind address (localhost for security — don't expose to network!)
CODE_SERVER_BIND=127.0.0.1

# MinIO S3 endpoint (for object storage)
MINIO_ENDPOINT=s3.localhost

# ⚠️  SECRET: MinIO access key
MINIO_ACCESS_KEY=minioadmin

# ⚠️  SECRET: MinIO secret key
MINIO_SECRET_KEY=minioadmin

# Enable local LLM support (Ollama)
OLLAMA_ENABLED=false

# Ollama container version (latest, 0.1.25, etc.)
OLLAMA_VERSION=latest

# ─────────────────────────────────────────────────────────────────────────────────────────────
# [VALIDATION] Do NOT edit below this line
# ─────────────────────────────────────────────────────────────────────────────────────────────

# REQUIRED: The following variables MUST be set before deployment:
# DEPLOYMENT_ENV, APEX_DOMAIN, PRIMARY_HOST_IP, GOOGLE_CLIENT_ID, 
# GOOGLE_CLIENT_SECRET, OAUTH2_PROXY_COOKIE_SECRET, POSTGRES_PASSWORD
#
# Validation runs on: docker-compose up (via scripts/validate-env.sh)
# On failure: Containers will not start (exit code 1)
#
# To validate manually:
#   bash scripts/validate-env.sh
#
# To view all variables with type info:
#   cat .env.schema.json | jq '.groups'

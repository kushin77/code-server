# GOV-005: Docker Compose Parameterization
POSTGRES_VERSION=15-alpine
REDIS_VERSION=7-alpine
CODE_SERVER_VERSION=4.115.0
OAUTH2_PROXY_VERSION=v7.5.1
CADDY_VERSION=2.9.1-alpine
PROMETHEUS_VERSION=v2.49.1
GRAFANA_VERSION=10.4.1
ALERTMANAGER_VERSION=v0.27.0
JAEGER_VERSION=1.55
HOST_IP=192.168.168.31
HOST_HOSTNAME=code-server.kushin.cloud
DOMAIN_BASE=192.168.168.31.nip.io
DOMAIN_PROD=kushin.cloud
CODE_SERVER_PASSWORD=changeme123!
CODE_SERVER_PORT=8080
CODE_SERVER_LOG_LEVEL=info
POSTGRES_DB=codeserver
POSTGRES_USER=codeserver
POSTGRES_PASSWORD=change_secure_password_here

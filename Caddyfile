# Caddyfile — Production IDE with Cloudflare Tunnel (Origin CA HTTPS)
# 
# IMPORTS: Shared blocks from Caddyfile.base
# Uses Cloudflare Origin CA certificate for origin->Cloudflare connection  
# Cloudflare Tunnel handles distribution; all HTTPS traffic proxied through tunnel
#
# Composition: @see Caddyfile.base for shared configuration (security_headers, cache_control_rules, etc.)

@import Caddyfile.base

{
    auto_https off
}

# HTTPS catch-all for all domains (Cloudflare Tunnel traffic)
:443 {
    import compression_standard
    import security_headers
    import cache_control_rules

    # Use Cloudflare Origin CA certificate (mounted in container at /etc/caddy/)
    tls /etc/caddy/ide.kushnir.crt /etc/caddy/ide.kushnir.key {
        protocols tls1.2 tls1.3
    }

    # Reverse proxy to code-server with production headers
    reverse_proxy code-server:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto https
        header_up CF-Connecting-IP {remote_host}
    }
}

# HTTP catch-all (port 80)
:80 {
    import compression_standard
    import security_headers

    # Health check endpoints work on HTTP
    @health path /health /healthz
    reverse_proxy @health code-server:8080

    # Redirect everything else to HTTPS
    redir / https://{host}{uri} permanent
}

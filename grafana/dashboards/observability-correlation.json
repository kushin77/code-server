{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.2.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Phase 23: Advanced Observability — Metrics Correlation & Anomaly Detection",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "SLO Dashboard",
      "url": "/d/phase23-slo",
      "type": "link",
      "icon": "external link"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "── Service Health Overview ──",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "red",    "value": 0.995 }
            ]
          },
          "unit": "percentunit",
          "max": 1,
          "min": 0.98
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "Availability SLI",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sli:availability:ratio_rate5m",
          "instant": true,
          "legendFormat": "Availability"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red",    "value": 0.2 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "p99 Latency",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sli:latency:p99_5m",
          "instant": true,
          "legendFormat": "p99 Latency"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red",    "value": 0.01 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Error Rate (5xx/s)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sli:error:ratio_rate5m",
          "instant": true,
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red",    "value": 6 }
            ]
          },
          "unit": "short",
          "displayName": "SLO Burn Rate"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "SLO Burn Rate (1h)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "slo:availability:burn_rate_1h",
          "instant": true,
          "legendFormat": "Burn Rate"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "── Correlation 1: Traffic → Latency ──",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99 Latency (s)" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Request Rate vs p99 Latency (Overload Detector)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "Requests/sec"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sli:latency:p99_5m",
          "legendFormat": "p99 Latency (s)"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p50 Latency (s)" },
            "properties": [{ "id": "unit", "value": "s" }]
          },
          {
            "matcher": { "id": "byName", "options": "p95 Latency (s)" },
            "properties": [{ "id": "unit", "value": "s" }]
          },
          {
            "matcher": { "id": "byName", "options": "p99 Latency (s)" },
            "properties": [{ "id": "unit", "value": "s" }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "title": "Latency Percentile Distribution",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sli:latency:p50_5m",
          "legendFormat": "p50 Latency (s)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sli:latency:p95_5m",
          "legendFormat": "p95 Latency (s)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sli:latency:p99_5m",
          "legendFormat": "p99 Latency (s)"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "── Correlation 2: CPU → Latency (CPU-Bound Detector) ──",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99 Latency (s)" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 21,
      "title": "CPU Usage vs p99 Latency",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sum(rate(process_cpu_seconds_total[5m]))",
          "legendFormat": "CPU Utilization"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sli:latency:p99_5m",
          "legendFormat": "p99 Latency (s)"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Latency z-score" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 22,
      "title": "Anomaly Z-Scores (σ deviation from baseline)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "anomaly:http_requests:zscore",
          "legendFormat": "Request Rate z-score"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "anomaly:latency_p99:zscore",
          "legendFormat": "Latency z-score"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "anomaly:error_rate:zscore",
          "legendFormat": "Error Rate z-score"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "vector(3)",
          "legendFormat": "Anomaly threshold (3σ)"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "title": "── Correlation 3: Model Inference Pressure ──",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU Usage" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "percentunit" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 31,
      "title": "Ollama Inference Rate vs CPU Usage",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sum(rate(ollama_inference_requests_total[5m])) or vector(0)",
          "legendFormat": "Inference calls/sec"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "sum(rate(process_cpu_seconds_total{job='ollama'}[5m])) or vector(0)",
          "legendFormat": "CPU Usage"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 40,
      "title": "── OTel Tracing Pipeline Health ──",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Export Success Ratio" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 41,
      "title": "OTel Pipeline Metrics (spans/s, queue fill, export success)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "otel:spans:drop_rate",
          "legendFormat": "Spans dropped/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "otel:queue:fill_ratio",
          "legendFormat": "Queue fill ratio"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "otel:export:success_ratio",
          "legendFormat": "Export Success Ratio"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 42,
      "title": "OTel Spans Received & Exported",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "rate(otelcol_receiver_accepted_spans_total[5m]) or vector(0)",
          "legendFormat": "Spans received/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid-001" },
          "expr": "rate(otelcol_exporter_sent_spans_total[5m]) or vector(0)",
          "legendFormat": "Spans exported/s"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["phase23", "observability", "correlation", "anomaly"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Phase 23: Correlation & Anomaly Detection",
  "uid": "phase23-correlation",
  "version": 1
}

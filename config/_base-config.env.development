# config/_base-config.env.development — Development environment overrides
# Configuration for local development

# ─ Development Deployment ─
DEPLOY_ENV=development
DEPLOY_HOST=localhost
DEPLOY_USER=developer
DEPLOY_TIMEOUT_SECONDS=60

# ─ Development Features (enable selectively for testing) ─
FEATURE_GPU_ENABLED=false  # Disable GPU for local development (may not have GPU)
FEATURE_MULTI_REGION=false  # Disable multi-region in development
FEATURE_OAUTH2=false  # Disable OAuth2 for local development (use password auth)
FEATURE_AUDIT_LOGGING=false  # Disable for speed
FEATURE_PERFORMANCE_OPTIMIZATION=false  # Disable for debugging
FEATURE_CHAOS_TESTING=true  # Enable for chaos engineering practices

# ─ Development Container Resources (smaller) ─
POSTGRES_MEMORY_LIMIT="512m"
POSTGRES_CPU_LIMIT="0.5"
REDIS_MEMORY_LIMIT="256m"
REDIS_CPU_LIMIT="0.25"
CODE_SERVER_MEMORY_LIMIT="1g"
CODE_SERVER_CPU_LIMIT="0.5"
OLLAMA_MEMORY_LIMIT="2g"

# ─ Development SLO (very relaxed) ─
SLO_AVAILABILITY_TARGET=95
SLO_P99_LATENCY_TARGET=500
SLO_ERROR_RATE_TARGET=2
SLO_ALERT_THRESHOLD_AVAILABILITY=90
SLO_ALERT_THRESHOLD_LATENCY=1000
SLO_ALERT_THRESHOLD_ERROR_RATE=5

# ─ Development Load Testing (minimal) ─
LOAD_TEST_DURATION_MS=60000
LOAD_TEST_PEAK_RPS=100
LOAD_TEST_RAMP_UP_MS=10000

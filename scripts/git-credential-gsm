#!/usr/bin/env bash
# git-credential-gsm — Git credential helper backed by GCP Secret Manager
#
# Implements the git credential helper protocol (get/store/erase).
# On `get`: fetches the GitHub PAT from GSM and returns it to git.
# On `store`/`erase`: no-op (GSM is the source of truth; PATs are not stored
#                     locally and are never written to ~/.git-credentials).
#
# Installation (run scripts/setup-git-credentials.sh):
#   sudo install -m755 scripts/git-credential-gsm /usr/local/bin/git-credential-gsm
#   git config --global credential.helper gsm
#
# Environment overrides:
#   GSM_PROJECT         GCP project ID (default: gcp-eiq)
#   GSM_SECRET_NAME     Secret name    (default: prod-github-token)
#
# Requires: gcloud (Google Cloud SDK)
# Fallback: if GSM is unavailable, exits non-zero so git tries the next helper
#           in the chain (safe degradation).
set -euo pipefail

readonly GSM_PROJECT="${GSM_PROJECT:-gcp-eiq}"
readonly GSM_SECRET_NAME="${GSM_SECRET_NAME:-prod-github-token}"
readonly GITHUB_HOST="github.com"

# Only respond to github.com requests — pass all other hosts through
protocol=""
host=""
while IFS='=' read -r key value; do
    case "$key" in
        protocol) protocol="$value" ;;
        host)     host="$value" ;;
    esac
done < /dev/stdin

operation="${1:-}"

if [[ "$operation" == "get" ]]; then
    # Only handle github.com; let other helpers handle everything else
    if [[ "$host" != "$GITHUB_HOST" ]]; then
        exit 1
    fi

    # Fetch PAT from GSM
    token=$(CLOUDSDK_CORE_DISABLE_PROMPTS=1 \
        gcloud --quiet secrets versions access latest \
            --secret="$GSM_SECRET_NAME" \
            --project="$GSM_PROJECT" \
            2>/dev/null) || {
        # GSM unavailable — exit non-zero so git falls back to next helper
        echo "git-credential-gsm: could not fetch from GSM project=${GSM_PROJECT} secret=${GSM_SECRET_NAME}" >&2
        exit 1
    }

    if [[ -z "$token" ]]; then
        echo "git-credential-gsm: GSM returned empty token for ${GSM_SECRET_NAME}" >&2
        exit 1
    fi

    # Return credentials to git in the expected key=value format
    printf 'protocol=%s\nhost=%s\nusername=x-oauth-token\npassword=%s\n' \
        "${protocol:-https}" \
        "$GITHUB_HOST" \
        "$token"
fi

# store / erase: intentional no-op — GSM is the source of truth
# Returning 0 prevents git from prompting or writing ~/.git-credentials
exit 0

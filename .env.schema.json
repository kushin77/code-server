{
  "version": "1.0",
  "description": "Master schema for environment variables — Single Source of Truth (SSOT)",
  "last_updated": "2026-04-16",
  "author": "Infrastructure Team",
  "purpose": "Define all environment variables with validation, type hints, and secret marking for Vault integration",
  
  "groups": {
    "infrastructure": {
      "description": "Core infrastructure and deployment configuration",
      "variables": {
        "DEPLOYMENT_ENV": {
          "type": "string",
          "enum": ["dev", "staging", "production", "onprem"],
          "required": true,
          "default": "dev",
          "example": "production",
          "description": "Deployment environment (controls behavior, logging, security levels)"
        },
        "APEX_DOMAIN": {
          "type": "string",
          "required": true,
          "format": "domain",
          "example": "kushnir.cloud",
          "description": "Root domain for all services (used by Caddyfile, DNS, certificates)",
          "production": "kushnir.cloud",
          "staging": "staging.kushnir.cloud",
          "dev": "localhost"
        },
        "PRIMARY_HOST_IP": {
          "type": "string",
          "format": "ipv4",
          "required": true,
          "example": "192.168.168.31",
          "description": "Primary production host IP (where Docker runs)",
          "production": "192.168.168.31",
          "staging": "192.168.168.32",
          "dev": "127.0.0.1"
        },
        "STANDBY_HOST_IP": {
          "type": "string",
          "format": "ipv4",
          "required": false,
          "example": "192.168.168.30",
          "description": "Failover/replica host IP",
          "production": "192.168.168.30",
          "staging": "192.168.168.33"
        },
        "SSH_PORT": {
          "type": "integer",
          "required": false,
          "default": 22,
          "min": 1024,
          "max": 65535,
          "description": "SSH port for deployment host"
        },
        "DOCKER_SOCKET": {
          "type": "string",
          "required": true,
          "default": "unix:///var/run/docker.sock",
          "example": "ssh://akushnir@192.168.168.31",
          "description": "Docker daemon socket (local or remote SSH)"
        }
      }
    },

    "authentication": {
      "description": "OAuth2, OIDC, and user authentication",
      "variables": {
        "GOOGLE_CLIENT_ID": {
          "type": "string",
          "secret": true,
          "vault_path": "secret/oauth2/google/client_id",
          "required": true,
          "example": "YOUR-CLIENT-ID.apps.googleusercontent.com",
          "description": "Google OAuth2 Client ID (from Google Cloud Console)",
          "notes": "Store in Vault, not in .env files"
        },
        "GOOGLE_CLIENT_SECRET": {
          "type": "string",
          "secret": true,
          "vault_path": "secret/oauth2/google/client_secret",
          "required": true,
          "description": "Google OAuth2 Client Secret",
          "notes": "Rotate every 90 days"
        },
        "OAUTH2_REDIRECT_URL": {
          "type": "string",
          "format": "url",
          "required": false,
          "example": "https://ide.kushnir.cloud/oauth2/callback",
          "description": "Legacy shared OAuth2 callback URL (prefer surface-specific vars below)"
        },
        "OAUTH2_PROXY_IDE_REDIRECT_URL": {
          "type": "string",
          "format": "url",
          "required": false,
          "example": "https://ide.kushnir.cloud/oauth2/callback",
          "description": "IDE OAuth2 callback URL (must match Google Console for ide.kushnir.cloud)"
        },
        "OAUTH2_PROXY_PORTAL_REDIRECT_URL": {
          "type": "string",
          "format": "url",
          "required": false,
          "example": "https://kushnir.cloud/oauth2/callback",
          "description": "Portal OAuth2 callback URL (must match Google Console for kushnir.cloud)"
        },
        "OAUTH2_PROXY_COOKIE_SECRET": {
          "type": "string",
          "secret": true,
          "vault_path": "secret/oauth2-proxy/cookie_secret",
          "required": true,
          "validation": "length==32",
          "format": "hex",
          "example": "0123456789abcdef0123456789abcdef",
          "description": "Cookie encryption key (32 hex chars = 16 bytes AES)",
          "generation": "openssl rand -hex 16"
        },
        "GITHUB_TOKEN": {
          "type": "string",
          "secret": true,
          "vault_path": "secret/github/token",
          "required": false,
          "description": "GitHub personal access token (for CI/CD)",
          "scopes": ["repo", "workflow", "admin:repo_hook"]
        }
      }
    },

    "database": {
      "description": "PostgreSQL and data store configuration",
      "variables": {
        "POSTGRES_HOST": {
          "type": "string",
          "required": true,
          "default": "postgres",
          "example": "postgres.default.svc.cluster.local",
          "description": "PostgreSQL hostname"
        },
        "POSTGRES_PORT": {
          "type": "integer",
          "required": false,
          "default": 5432,
          "description": "PostgreSQL port"
        },
        "POSTGRES_DB": {
          "type": "string",
          "required": true,
          "default": "code_server",
          "description": "Database name"
        },
        "POSTGRES_USER": {
          "type": "string",
          "required": true,
          "default": "postgres",
          "description": "PostgreSQL user"
        },
        "POSTGRES_PASSWORD": {
          "type": "string",
          "secret": true,
          "vault_path": "secret/postgres/password",
          "required": true,
          "description": "PostgreSQL password"
        },
        "REDIS_HOST": {
          "type": "string",
          "required": true,
          "default": "redis",
          "description": "Redis hostname"
        },
        "REDIS_PORT": {
          "type": "integer",
          "required": false,
          "default": 6379,
          "description": "Redis port"
        }
      }
    },

    "security": {
      "description": "Security and encryption configuration",
      "variables": {
        "TLS_CERT_FILE": {
          "type": "string",
          "required": false,
          "example": "/etc/caddy/certs/ide.kushnir.cloud.crt",
          "description": "TLS certificate file path (auto-generated by Let's Encrypt if not provided)"
        },
        "TLS_KEY_FILE": {
          "type": "string",
          "required": false,
          "example": "/etc/caddy/certs/ide.kushnir.cloud.key",
          "description": "TLS private key file path (auto-generated by Let's Encrypt if not provided)"
        },
        "SOPS_AGE_KEY_FILE": {
          "type": "string",
          "required": false,
          "example": "/home/akushnir/.sops/age/keys.txt",
          "description": "SOPS age key file for secret encryption (development only)"
        },
        "SOPS_ENABLED": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Enable SOPS secret encryption for sensitive files"
        }
      }
    },

    "observability": {
      "description": "Logging, metrics, and tracing",
      "variables": {
        "LOG_LEVEL": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "required": false,
          "default": "info",
          "description": "Global log level"
        },
        "PROMETHEUS_PORT": {
          "type": "integer",
          "required": false,
          "default": 9090,
          "description": "Prometheus metrics port"
        },
        "GRAFANA_PORT": {
          "type": "integer",
          "required": false,
          "default": 3000,
          "description": "Grafana dashboard port"
        },
        "JAEGER_ENABLED": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Enable distributed tracing (Jaeger)"
        },
        "JAEGER_ENDPOINT": {
          "type": "string",
          "format": "url",
          "required": false,
          "default": "http://localhost:16686",
          "description": "Jaeger UI endpoint"
        },
        "LOKI_HOST": {
          "type": "string",
          "required": false,
          "default": "loki",
          "description": "Loki log aggregation host"
        },
        "LOKI_PORT": {
          "type": "integer",
          "required": false,
          "default": 3100,
          "description": "Loki port"
        }
      }
    },

    "services": {
      "description": "Service-specific configuration",
      "variables": {
        "CODE_SERVER_PORT": {
          "type": "integer",
          "required": false,
          "default": 8080,
          "description": "Code-server application port (internal, behind OAuth2 proxy)"
        },
        "CODE_SERVER_BIND": {
          "type": "string",
          "required": false,
          "default": "127.0.0.1",
          "description": "Code-server bind address (localhost for security)"
        },
        "MINIO_ENDPOINT": {
          "type": "string",
          "format": "domain",
          "required": false,
          "example": "s3.kushnir.cloud",
          "description": "MinIO S3 endpoint"
        },
        "MINIO_ACCESS_KEY": {
          "type": "string",
          "secret": true,
          "vault_path": "secret/minio/access_key",
          "required": false,
          "description": "MinIO access key"
        },
        "MINIO_SECRET_KEY": {
          "type": "string",
          "secret": true,
          "vault_path": "secret/minio/secret_key",
          "required": false,
          "description": "MinIO secret key"
        },
        "OLLAMA_ENABLED": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Enable local LLM (Ollama)"
        },
        "OLLAMA_VERSION": {
          "type": "string",
          "required": false,
          "default": "latest",
          "example": "0.1.25",
          "description": "Ollama container version"
        }
      }
    }
  },

  "loading_order": {
    "priority": "highest_last",
    "sequence": [
      {
        "step": 1,
        "file": ".env.defaults",
        "description": "All default values (lowest priority)",
        "tracked": true
      },
      {
        "step": 2,
        "file": ".env.${DEPLOYMENT_ENV}",
        "description": "Environment-specific overrides (prod, staging, dev)",
        "tracked": true,
        "examples": [".env.production", ".env.staging", ".env.dev"]
      },
      {
        "step": 3,
        "file": "${HOME}/.code-server/.env",
        "description": "User-local overrides (not tracked, for local testing)",
        "tracked": false
      },
      {
        "step": 4,
        "file": "Vault secrets",
        "description": "Runtime secrets from Vault (highest priority)",
        "tracked": false,
        "note": "Requires SOPS or Vault client authentication"
      }
    ]
  },

  "validation": {
    "required_variables": [
      "DEPLOYMENT_ENV",
      "APEX_DOMAIN",
      "PRIMARY_HOST_IP",
      "GOOGLE_CLIENT_ID",
      "GOOGLE_CLIENT_SECRET",
      "OAUTH2_PROXY_COOKIE_SECRET",
      "POSTGRES_PASSWORD"
    ],
    "validation_script": "scripts/validate-env.sh",
    "generation_time": "On every docker-compose up",
    "on_missing": "FAIL (exit 1) — prevents container startup"
  },

  "secret_variables": {
    "description": "Variables marked as secrets (should not be committed to git)",
    "variables": [
      "GOOGLE_CLIENT_SECRET",
      "OAUTH2_PROXY_COOKIE_SECRET",
      "GITHUB_TOKEN",
      "POSTGRES_PASSWORD",
      "MINIO_SECRET_KEY",
      "SOPS_AGE_KEY_FILE"
    ],
    "storage": "Vault (production) or .gitignored .env.local (development)",
    "rotation_policy": "90 days (or immediately if compromised)"
  },

  "implementation_phases": {
    "phase_1": {
      "name": "Schema Deployment",
      "target_date": "2026-04-16",
      "tasks": [
        "Introduce .env.schema.json (this file)",
        "Document all variables with types and defaults",
        "Mark secrets for Vault integration",
        "Define validation rules"
      ]
    },
    "phase_2": {
      "name": "Auto-Generate Documentation",
      "target_date": "2026-04-17",
      "tasks": [
        "Run scripts/generate-env-docs.sh",
        "Create ENV_REFERENCE.md from schema",
        "Auto-update CONTRIBUTING.md with variable requirements"
      ]
    },
    "phase_3": {
      "name": "Deprecate Old Files",
      "target_date": "2026-04-23",
      "tasks": [
        "Archive old .env files to .archived/",
        "Update docker-compose.yml to load schema-validated vars",
        "Add validation to CI/CD (GitHub Actions)"
      ]
    },
    "phase_4": {
      "name": "Automated Loading",
      "target_date": "2026-04-30",
      "tasks": [
        "Implement automatic .env schema validation in Makefile",
        "Integrate with Vault for production secrets",
        "Enable per-environment env file loading"
      ]
    }
  },

  "tooling": {
    "validation": {
      "script": "scripts/validate-env.sh",
      "purpose": "Check all required variables are set before deployment",
      "usage": "bash scripts/validate-env.sh",
      "exit_codes": {
        "0": "All validation passed",
        "1": "Missing required variable(s)",
        "2": "Invalid variable format"
      }
    },
    "documentation_generation": {
      "script": "scripts/generate-env-docs.sh",
      "purpose": "Auto-generate markdown documentation from this schema",
      "usage": "bash scripts/generate-env-docs.sh > ENV_REFERENCE.md",
      "output": "Markdown table with all variables, types, examples, defaults"
    },
    "vault_integration": {
      "tool": "Vault CLI or GitHub Actions",
      "purpose": "Fetch secrets marked with vault_path at runtime",
      "usage": "vault kv get secret/oauth2/google/client_id",
      "status": "Not yet implemented (Phase 4)"
    }
  }
}

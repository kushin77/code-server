# -----------------------------------------------------------------------------
# Google Secret Manager (GSM) integration
# Mirrors Ollama-style env-driven config used by backend/src/lib/gsm.ts
# -----------------------------------------------------------------------------

# Enable GSM-backed secret resolution
OLLAMA_GSM_ENABLED=false

# GCP project that contains secrets (required when OLLAMA_GSM_ENABLED=true)
OLLAMA_GSM_PROJECT_ID=

# Optional override for GitHub PAT secret name in GSM
# Default in code: prod-github-token
GSM_GITHUB_TOKEN_SECRET=prod-github-token

# Optional ADC credentials file for local/dev if not using workload identity
GOOGLE_APPLICATION_CREDENTIALS=

# ════════════════════════════════════════════════════════════════════════════
# Code-Server Enterprise Configuration
# On-prem VSCode server at 192.168.168.31 behind Cloudflare Tunnel
# Usage: cp .env.example .env && edit .env with your values
# ════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Code-Server Authentication
# ─────────────────────────────────────────────────────────────────────────────
CODE_SERVER_PASSWORD=change-me-strong-password-min-20-chars

# ─────────────────────────────────────────────────────────────────────────────
# Networking & Domain
# ─────────────────────────────────────────────────────────────────────────────
DEPLOY_HOST=192.168.168.31
DOMAIN=kushnir.cloud
ACME_EMAIL=security@kushnir.cloud

# ─────────────────────────────────────────────────────────────────────────────
# OAuth2 Proxy / Google Authentication (for code-server access)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH2_PROXY_COOKIE_SECRET=your-32-hex-char-secret-from-openssl-rand-hex-16
# Optional IDE-specific override (falls back to GOOGLE_CLIENT_ID/SECRET)
OAUTH2_IDE_GOOGLE_CLIENT_ID=
OAUTH2_IDE_GOOGLE_CLIENT_SECRET=
# Optional portal-specific override (use this if portal uses a different OAuth app)
OAUTH2_PORTAL_GOOGLE_CLIENT_ID=
OAUTH2_PORTAL_GOOGLE_CLIENT_SECRET=
# OAuth callback URLs (must match Google Console authorized redirect URIs)
OAUTH2_PROXY_IDE_REDIRECT_URL=https://ide.kushnir.cloud/oauth2/callback
OAUTH2_PROXY_PORTAL_REDIRECT_URL=https://kushnir.cloud/oauth2/callback
# Optional domain constraints. Use * to avoid Google org_internal 403 before the email allowlist runs.
OAUTH2_PROXY_IDE_EMAIL_DOMAINS=*
OAUTH2_PROXY_PORTAL_EMAIL_DOMAINS=*

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Integration
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# ─────────────────────────────────────────────────────────────────────────────
# Ollama LLM Configuration (GPU acceleration)
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_NUM_THREAD=16
OLLAMA_NUM_GPU=1
OLLAMA_GPU_LAYERS=99
OLLAMA_FLASH_ATTENTION=1
OLLAMA_NUM_PARALLEL=4

# ─────────────────────────────────────────────────────────────────────────────
# NAS Storage (192.168.168.56 — GSM-managed, NFSv4)
# Shared across .31 and .42 — single source of truth for stateful data.
# NFS export structure on NAS:
#   /export/code-server/workspace   → code-server-workspace volume
#   /export/code-server/profile     → code-server-profile volume
#   /export/code-server/profile-backups → code-server-profile-backups volume
#   /export/ollama                  → ollama-data volume
#   /export/postgres/backups        → postgres-backup volume
# DB engine volumes (postgres-data, redis-data, prometheus-data) stay local.
# ─────────────────────────────────────────────────────────────────────────────
NAS_HOST=192.168.168.56
NAS_EXPORT_PATH=/export

# ─────────────────────────────────────────────────────────────────────────────
# Monitoring & Observability
# ─────────────────────────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=15d
GRAFANA_ADMIN_PASSWORD=admin123
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Security & Secrets (use Google Secret Manager in production)
# ─────────────────────────────────────────────────────────────────────────────
GSM_PROJECT_ID=your-gcp-project-id
GSM_SECRETS_PATH=projects/your-project/secrets

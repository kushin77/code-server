# Portable Caddyfile — domain driven by DOMAIN env var (set in docker-compose or .env)
# Caddy reads {$DOMAIN} at startup from the container environment
# TLS: Let's Encrypt via HTTP-01 challenge (standard method)
# Note: Requires ports 80/443 to be open for ACME verification

# Global options — production CA only (disables staging fallback)
{
    acme_ca https://acme-v02.api.letsencrypt.org/directory
}

{$DOMAIN} {
    # HTTP-01 challenge — standard Let's Encrypt method (requires open 80/443)
    # For DNS-01 (GoDaddy) without open ports, rebuild Caddy with custom plugins

    encode gzip

    # Security headers
    header {
        X-Content-Type-Options nosniff
        # SAMEORIGIN (not DENY) — code-server uses iframes internally
        X-Frame-Options SAMEORIGIN
        X-XSS-Protection "1; mode=block"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # CSP: allow wss/ws for IDE terminals and extension host; blob:/data: for fonts/worker
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' wss: ws: https:; worker-src 'self' blob:; frame-src 'self';"
        -Server
    }

    # One-shot endpoint to clear stale workbench cache/storage in a regular profile.
    @reset path /reset-browser-state
    header @reset Clear-Site-Data "\"cache\", \"storage\""
    respond @reset 200

    # Prevent stale JS/CSS bundles from persisting across patched deployments.
    @stableAssets path /stable-*
    header @stableAssets Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
    header @stableAssets Pragma "no-cache"
    header @stableAssets Expires "0"

    # ─── API Routes ──────────────────────────────────────────────────────────
    # RBAC API: auth, users, roles, MFA, OAuth2/OpenID Connect
    @api {
        path /api/* /auth/.well-known/* /auth/authorize /auth/token /auth/userinfo /auth/validate /auth/refresh /auth/logout /auth/jwks
    }
    reverse_proxy @api rbac-api:3001 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For {remote_host}
    }

    # ─── Admin Portal ─────────────────────────────────────────────────────────
    # Appsmith: Low-code admin panel for user/role/organization management
    @appsmith path /appsmith* /appsmith/*
    reverse_proxy @appsmith appsmith:80 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For {remote_host}
    }

    # ─── User Management UI ───────────────────────────────────────────────────
    # React + TypeScript user management interface
    # Integrated with RBAC API for authentication and authorization
    @admin path /admin* /admin/*
    reverse_proxy @admin frontend:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For {remote_host}
    }

    # ─── Developer Portal ─────────────────────────────────────────────────────
    # Backstage: Software catalog, documentation, scaffolder, onboarding
    @backstage path /backstage* /backstage/*
    reverse_proxy @backstage backstage:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For {remote_host}
    }

    # ─── Frontend & Code Server ─────────────────────────────────────────────
    # Everything else → oauth2-proxy (handles Google Auth then forwards to code-server)
    reverse_proxy oauth2-proxy:4180 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto https
        # Preserve client IP through proxy chain
        header_up X-Forwarded-For {remote_host}
    }
}

# HTTP → HTTPS redirect
http://{$DOMAIN} {
    redir https://{host}{uri} permanent
}

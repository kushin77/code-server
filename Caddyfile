# Caddyfile — Development (Default)
# COMPOSITION: @import Caddyfile.base for shared blocks
# Configuration: HTTP only, no TLS, development-friendly caching

@import Caddyfile.base

# Global configuration for development
{
    auto_https off
    log default {
        format json
    }
}

# HTTP only listener (development)
:80 {
    import compression_standard
    import security_headers
    import reverse_proxy_code_server
    
    # Development: disable caching for rapid iteration
    header Cache-Control "no-cache, no-store, must-revalidate"
}

# Backend OpenTelemetry Configuration
# Copy to .env and customize for your environment
#
# Generated by: Phase 3 observability spine - TASK 6 (Backend Instrumentation)

# Environment: development, staging, production
NODE_ENV=development

# OpenTelemetry Configuration
# ─────────────────────────────────────────────────────────────────
# OTLP Exporter endpoint (OpenTelemetry Collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Service metadata
OTEL_SERVICE_NAME=code-server-backend
OTEL_SERVICE_VERSION=0.1.0

# Tracing
# - 1.0 = 100% (all requests sampled) - development
# - 0.1 = 10% (1 in 10) - staging
# - 0.01 = 1% (1 in 100) - production (configurable)
OTEL_TRACES_SAMPLER=always_on
OTEL_TRACES_SAMPLER_ARG=0.01

# Logging
# - true = enable structured JSON logging with trace context
# - false = disable structured logging
OTEL_STRUCTURED_LOGGING_ENABLED=true

# Database Configuration
# ─────────────────────────────────────────────────────────────────
# PostgreSQL connection (used by database instrumentation)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=code_server
POSTGRES_PASSWORD=changeme
POSTGRES_DB=code_server
POSTGRES_POOL_SIZE=10

# Slow query threshold (milliseconds)
# Queries taking longer will be logged with full trace context
POSTGRES_SLOW_QUERY_THRESHOLD_MS=1000

# Cache Configuration
# ─────────────────────────────────────────────────────────────────
# Redis connection (used by Redis instrumentation)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=50

# Application Configuration
# ─────────────────────────────────────────────────────────────────
# Port to listen on
PORT=8080

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable verbose OTEL logging (development only)
OTEL_DEBUG=false

# Health check endpoints
HEALTH_CHECK_INTERVAL_MS=30000
HEALTH_CHECK_TIMEOUT_MS=5000

# Performance thresholds for alerting
# ─────────────────────────────────────────────────────────────────
# Alert if p99 latency exceeds this (milliseconds)
LATENCY_THRESHOLD_P99_MS=500

# Alert if error rate exceeds this (percentage)
ERROR_RATE_THRESHOLD_PERCENT=1.0

# Alert if memory usage exceeds this (percentage of available)
MEMORY_THRESHOLD_PERCENT=80

# Request tracing
# ─────────────────────────────────────────────────────────────────
# Generate and propagate trace IDs for all requests
TRACE_ID_GENERATION_ENABLED=true

# Debug mode: Escal ate trace sampling to 100% for debugging
DEBUG_MODE_ENABLED=false

# Debug mode timeout (minutes) - auto-revert if forgotten
DEBUG_MODE_TIMEOUT_MINUTES=15

# Feature flags
# ─────────────────────────────────────────────────────────────────
# Enable distributed tracing across services
DISTRIBUTED_TRACING_ENABLED=true

# Enable correlation ID propagation
CORRELATION_ID_PROPAGATION_ENABLED=true

# Enable query instrumentation (trace context injection)
QUERY_INSTRUMENTATION_ENABLED=true

# Enable cache operation tracing
CACHE_INSTRUMENTATION_ENABLED=true

# Production Caddyfile — ide.kushnir.cloud
# Full TLS 1.3 enforcement, CloudFlare integration, enterprise headers
# Target: A+ SSL Labs rating, enterprise compliance
#
# IMPORTS: Shared blocks from Caddyfile.base
# @see Caddyfile.base for common security headers, cache rules, compression

@import Caddyfile.base
    # Global configuration for all domains
    auto_https off  # We'll handle HTTPS explicitly for flexibility
    
    # Email for ACME certificate notifications (Let's Encrypt)
    email {$ACME_EMAIL:security@example.com}
    
    # ACME provider configuration (Let's Encrypt production)
    acme_dns cloudflare {$CLOUDFLARE_API_TOKEN}
    acme_ca https://acme-v02.api.letsencrypt.org/directory
    
    # Production logging
    log default {
        format json
        output file /var/log/caddy/caddy.log {
            roll_size 100mb
            roll_keep 10
            roll_keep_for 720h
        }
        level info
    }
}

# ════════════════════════════════════════════════════════════
# IDE SERVICE (ide.kushnir.cloud)
# ════════════════════════════════════════════════════════════

ide.kushnir.cloud {
    # Automatic HTTPS via Let's Encrypt with CloudFlare DNS-01 challenge
    # Allows for wildcard certificates and DNS-based validation
    tls {
        issuer acme {
            disable_issuance_limits
            challenges dns cloudflare
            resolvers 1.1.1.1 1.0.0.1  # CloudFlare nameservers
        }
    }
    
    # ────────────────────────────────────────────────────
    # Use common security headers from Caddyfile.base
    # ────────────────────────────────────────────────────
    
    import security_headers_strict
    
    # ────────────────────────────────────────────────────
    # HTTP/3 and compression
    # ────────────────────────────────────────────────────
    
    # HTTP/3 (QUIC) support
    servers {
        protocols h1 h2 h3
        strict_sni_host on
    }
    
    # Advanced compression from Caddyfile.base
    import compression_advanced
    
    # ────────────────────────────────────────────────────
    # Rate Limiting (DDoS Protection) from Caddyfile.base
    # ────────────────────────────────────────────────────
    
    import rate_limiting_production
    
    # ────────────────────────────────────────────────────
    # Request ID and Tracing
    # ────────────────────────────────────────────────────
    
    # Generate request ID for correlation
    request_id_header X-Request-ID
    header -X-Request-ID  # Remove from response
    
    # ────────────────────────────────────────────────────
    # Reverse Proxy Configuration
    # ────────────────────────────────────────────────────
    
    # OAuth2 endpoint (protected)
    @oauth_callback path /oauth2/callback
    reverse_proxy @oauth_callback oauth2-proxy:4180 {
        # Pass headers for authentication
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host {host}
        header_up X-Original-URI {uri}
        
        # OpenTelemetry tracing
        header_up X-Trace-ID {http.request.id}
        
        # Timeouts
        transport http {
            read_timeout 30s
            write_timeout 30s
            dial_timeout 10s
        }
    }
    
    # Health check endpoint (no auth required)
    @health_check path /health
    respond @health_check "OK\n" 200 {
        header Content-Type "text/plain; charset=UTF-8"
    }
    
    # All other traffic goes through OAuth2-Proxy → Code-Server
    # OAuth2-Proxy handles authentication before forwarding
    reverse_proxy oauth2-proxy:4180 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host {host}
        
        # Tracing
        header_up X-Trace-ID {http.request.id}
        
        # Connection management
        transport http {
            read_timeout 60s
            write_timeout 60s
            dial_timeout 10s
            max_conns_per_host 100
            keep_alive_timeout 90s
        }
        
        # WebSocket support (for Code-Server terminal)
        transport http {
            websocket {
                read_timeout 30m
                write_timeout 30m
            }
        }
    }
    
    # ────────────────────────────────────────────────────
    # Error handling
    # ────────────────────────────────────────────────────
    
    handle_errors {
        # Hide error details from clients (security)
        header Content-Type "application/json"
        respond `{"error": "internal server error", "code": {http.error.status_code}}` {http.error.status_code}
    }
    
    # ────────────────────────────────────────────────────
    # Metrics and monitoring
    # ────────────────────────────────────────────────────
    
    # Prometheus metrics endpoint (unauthenticated, internal only)
    @metrics_internal remote_ip 127.0.0.1 ::1
    reverse_proxy @metrics_internal localhost:2019/metrics {
        uri /metrics
    }
    
    # ────────────────────────────────────────────────────
    # Logging configuration
    # ────────────────────────────────────────────────────
    
    log {
        output file /var/log/caddy/ide.kushnir.cloud.log {
            roll_size 100mb
            roll_keep 14  # 14 days
            roll_keep_for 336h
        }
        format json
        level info
    }
}

# ════════════════════════════════════════════════════════════
# WILDCARD SUBDOMAIN (*.ide.kushnir.cloud)
# For multi-tenant or future expansion
# ════════════════════════════════════════════════════════════

*.ide.kushnir.cloud {
    # TLS with wildcard certificate (issued via main domain)
    tls {
        issuer acme {
            disable_issuance_limits
            challenges dns cloudflare
        }
    }
    
    # Security headers (same as main domain)
    header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    header Content-Security-Policy "default-src 'self'"
    header X-Content-Type-Options "nosniff"
    header X-Frame-Options "DENY"
    
    # Default response for wildcard
    respond "Subdomain not configured" 404
    
    log {
        format json
        level info
    }
}

# ════════════════════════════════════════════════════════════
# LOCALHOST (for development and internal testing)
# ════════════════════════════════════════════════════════════

localhost {
    # Self-signed certificate for internal testing
    tls internal
    
    # Reverse proxy to Code-Server (for testing without OAuth)
    reverse_proxy localhost:8080 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto https
        header_up Upgrade websocket
        header_up Connection Upgrade
    }
}


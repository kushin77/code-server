# ═══════════════════════════════════════════════════════════════════════════════
# CI TESTING ENVIRONMENT — kushin77/code-server
# Used by GitHub Actions workflows for validation only
# DO NOT use these credentials in production
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Domain & Networking ──────────────────────────────────────────────────────
DOMAIN=ide.kushnir.cloud
ACME_EMAIL=ops@kushnir.cloud

# ─── Code-Server ──────────────────────────────────────────────────────────────
CODE_SERVER_PASSWORD=ci-test-password-12345
CODE_SERVER_PORT=8080
CODE_SERVER_BIND_ADDR=0.0.0.0
CODE_SERVER_HEALTHCHECK_RETRIES=3
CODE_SERVER_HEALTHCHECK_TIMEOUT=10s

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_VERSION=15.2
POSTGRES_DB=codeserver
POSTGRES_USER=codeserver
POSTGRES_PASSWORD=ci-test-postgres-password-12345
POSTGRES_PORT=5432
POSTGRES_MEMORY_RESERVE=256m
POSTGRES_MEMORY_LIMIT=512m

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_VERSION=7.2.4
REDIS_PASSWORD=ci-test-redis-password-12345
REDIS_PORT=6379
REDIS_MEMORY_RESERVE=64m
REDIS_MEMORY_LIMIT=128m

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_VERSION=10.2.3
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ci-test-grafana-password-12345
GRAFANA_PORT=3000

# ─── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_VERSION=v2.48.0
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d

# ─── AlertManager ─────────────────────────────────────────────────────────────
ALERTMANAGER_VERSION=v0.26.0
ALERTMANAGER_PORT=9093

# ─── Jaeger ───────────────────────────────────────────────────────────────────
JAEGER_VERSION=1.50
JAEGER_PORT=16686

# ─── CoreDNS ──────────────────────────────────────────────────────────────────
COREDNS_VERSION=1.11.1

# ─── Caddy ────────────────────────────────────────────────────────────────────
CADDY_VERSION=2.9.1
CADDY_PORT=80
CADDY_TLS_PORT=443

# ─── OAuth2-Proxy ─────────────────────────────────────────────────────────────
OAUTH2_PROXY_VERSION=v7.5.1
OAUTH2_PROXY_PORT=4180
# Cookie secret MUST be exactly 16 bytes (32 hex characters) for AES-128 encryption
# Generated via: openssl rand -hex 16
OAUTH2_PROXY_COOKIE_SECRET=0102030405060708090a0b0c0d0e0f10
GOOGLE_CLIENT_ID=ci-test-client.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ci-test-client-secret-value
GOOGLE_OAUTH_CALLBACK_URL=https://ide.kushnir.cloud/oauth2/callback

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=ci-test-tunnel-token-placeholder
CLOUDFLARE_ACCOUNT_ID=ci-test-account-id
CLOUDFLARE_TUNNEL_NAME=code-server-ci-test

# ─── Ollama (GPU Model Server) ────────────────────────────────────────────────
OLLAMA_VERSION=0.1.17
OLLAMA_NUM_THREAD=2
OLLAMA_PORT=11434
OLLAMA_MODELS_DIR=/var/lib/ollama/models
OLLAMA_CUDA_COMPUTE_CAP=86
OLLAMA_NUM_GPU=1

# ─── Git Proxy ────────────────────────────────────────────────────────────────
GIT_PROXY_PORT=6006
GIT_HTTPS_PROXY=socks5://git-proxy:6006

# ─── SSH Proxy ────────────────────────────────────────────────────────────────
SSH_PROXY_PORT=2222
SSH_KNOWN_HOSTS=/home/codeserver/.ssh/known_hosts

# ─── Docker Logging ───────────────────────────────────────────────────────────
DOCKER_LOGGING_DRIVER=json-file
DOCKER_LOGGING_MAX_SIZE=10m
DOCKER_LOGGING_MAX_FILE=10

# ─── Network ──────────────────────────────────────────────────────────────────
PROD_SUBNET=192.168.168.0/24
DOCKER_INTERNAL_SUBNET=172.20.0.0/16

# ─── Security ──────────────────────────────────────────────────────────────────
DISABLE_PASSWORD_AUTH=false
REQUIRE_2FA=false
LOG_LEVEL=info
VERBOSE_LOGGING=false

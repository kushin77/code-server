http://ide.kushnir.cloud, http://kushnir.cloud {
    redir https://{host}{uri} permanent
}

# Keep a local responder for container health probes that hit localhost:80
http://localhost {
    respond "OK" 200
}

ide.kushnir.cloud {

    encode gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        X-XSS-Protection "1; mode=block"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    @health path /health /healthz /ping
    respond @health "OK" 200

    @portal path /portal /portal/*
    handle @portal {
        uri strip_prefix /portal
        root * /srv/portal
        file_server
    }

    # oauth2-proxy endpoints must pass through directly (they ARE the auth flow)
    @oauth2 path /oauth2 /oauth2/*
    handle @oauth2 {
        reverse_proxy oauth2-proxy:4180 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # Grafana - SSO via forward_auth then proxy with auth header
    @grafana path /grafana /grafana/*
    handle @grafana {
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-User X-Auth-Request-Email
        }
        uri strip_prefix /grafana
        reverse_proxy grafana:3000 {
            header_up X-WEBAUTH-USER {http.reverse_proxy.header.X-Auth-Request-Email}
            header_up Host {host}
        }
    }

    # Prometheus - SSO via forward_auth
    @prometheus path /prometheus /prometheus/*
    handle @prometheus {
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-User X-Auth-Request-Email
        }
        uri strip_prefix /prometheus
        reverse_proxy prometheus:9090
    }

    # AlertManager - SSO via forward_auth
    @alertmanager path /alertmanager /alertmanager/*
    handle @alertmanager {
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-User X-Auth-Request-Email
        }
        uri strip_prefix /alertmanager
        reverse_proxy alertmanager:9093
    }

    # Jaeger - SSO via forward_auth
    @jaeger path /jaeger /jaeger/*
    handle @jaeger {
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-User X-Auth-Request-Email
        }
        uri strip_prefix /jaeger
        reverse_proxy jaeger:16686
    }

    # Unauthenticated requests -> redirect to oauth2 sign-in with return URL
    handle_errors 401 {
        redir /oauth2/sign_in?rd={http.request.orig_uri} 302
    }

    # Default: code-server (via oauth2-proxy full reverse proxy)
    reverse_proxy oauth2-proxy:4180 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto https
        transport http {
            dial_timeout 10s
            read_timeout 0
            write_timeout 0
        }
    }
}

kushnir.cloud {

    redir https://ide.kushnir.cloud{uri} permanent
}

# =============================================================================
# Caddyfile -- PRODUCTION caddy v2.9.1-alpine
# Host   : 192.168.168.31
# TLS    : Let's Encrypt ACME (production real certificates)
# Routes : ide, grafana, prometheus, alertmanager, jaeger, ollama
# Updated: 2026-04-15 (caddy fmt compliant, real TLS for production)
# =============================================================================

{
	admin off

	log {
		format json
		output stdout
		level  WARN
	}

	# Let's Encrypt ACME configuration for production
	acme_ca https://acme-v02.api.letsencrypt.org/directory
	email admin@kushnir.cloud
}

# -- Shared security headers --------------------------------------------------
(security_headers) {
	header {
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "SAMEORIGIN"
		X-XSS-Protection          "1; mode=block"
		Referrer-Policy           "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		-Server
		-X-Powered-By
	}
}

# -- On-prem + VPN access matcher --------------------------------------------
# Subnets: LAN 192.168.168.0/24, WireGuard 10.8.0.0/24, OpenVPN 10.0.0.0/8
(internal_only) {
	@denied not remote_ip 192.168.168.0/24 10.8.0.0/24 10.0.0.0/8
	handle @denied {
		respond "Forbidden" 403
	}
}

# -- IDE (code-server via oauth2-proxy) -- REAL CERTIFICATES VIA LET'S ENCRYPT -----
ide.kushnir.cloud {
	encode gzip
	import security_headers

	reverse_proxy oauth2-proxy:4180 {
		header_up Host       {upstream_hostport}
		header_up X-Real-IP  {remote_host}
	}
}

# -- Grafana -- REAL CERTIFICATES VIA LET'S ENCRYPT ----
grafana.kushnir.cloud {
	encode gzip
	import security_headers
	reverse_proxy grafana:3000
}

# -- Prometheus (LAN + VPN only) -- REAL CERTIFICATES VIA LET'S ENCRYPT ----
prometheus.kushnir.cloud {
	encode gzip
	import security_headers
	import internal_only

	handle {
		reverse_proxy prometheus:9090
	}
}

# -- AlertManager (LAN + VPN only) -- REAL CERTIFICATES VIA LET'S ENCRYPT ----
alertmanager.kushnir.cloud {
	encode gzip
	import security_headers
	import internal_only

	handle {
		reverse_proxy alertmanager:9093
	}
}

# -- Jaeger Tracing UI (LAN + VPN only) -- REAL CERTIFICATES VIA LET'S ENCRYPT ----
jaeger.kushnir.cloud {
	encode gzip
	import security_headers
	import internal_only

	handle {
		reverse_proxy jaeger:16686
	}
}

# -- Ollama API (LAN + VPN only) -- REAL CERTIFICATES VIA LET'S ENCRYPT ----
ollama.kushnir.cloud {
	import security_headers
	import internal_only

	handle {
		reverse_proxy ollama:11434
	}
}

# -- HTTP -> HTTPS redirect ---------------------------------------------------
:80 {
	redir https://{host}{uri} 301
}


# ═══════════════════════════════════════════════════════════════════════════════
# Caddyfile — PRODUCTION
# Host: 192.168.168.31 | TLS: internal (on-prem self-signed)
# Routes: ide, grafana, prometheus, alertmanager, jaeger, ollama
# ═══════════════════════════════════════════════════════════════════════════════

{
    admin off
    log {
        format json
        output stdout
        level  WARN
    }
}

# ── Shared security header snippet ──────────────────────────────────────────
(security_headers) {
    header {
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "SAMEORIGIN"
        X-XSS-Protection          "1; mode=block"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=63072000; includeSubDomains"
        -Server
        -X-Powered-By
    }
}

# ── IDE (code-server via oauth2-proxy) ──────────────────────────────────────
ide.kushnir.cloud {
    tls internal
    encode gzip
    import security_headers

    # Auth via oauth2-proxy
    reverse_proxy oauth2-proxy:4180 {
        header_up Host              {upstream_hostport}
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-For   {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    log {
        output stdout
        format json
    }
}

# ── Grafana ──────────────────────────────────────────────────────────────────
grafana.kushnir.cloud {
    tls internal
    encode gzip
    import security_headers
    reverse_proxy grafana:3000
    log {
        output stdout
        format json
    }
}

# ── Prometheus (internal only — no oauth, restrict to VPN) ──────────────────
prometheus.kushnir.cloud {
    tls internal
    encode gzip
    import security_headers

    # Restrict to on-prem subnet + VPN range
    @allowed remote_ip 192.168.168.0/24 10.8.0.0/24
    handle @allowed {
        reverse_proxy prometheus:9090
    }
    handle {
        respond "Forbidden" 403
    }
    log {
        output stdout
        format json
    }
}

# ── AlertManager ─────────────────────────────────────────────────────────────
alertmanager.kushnir.cloud {
    tls internal
    encode gzip
    import security_headers

    @allowed remote_ip 192.168.168.0/24 10.8.0.0/24
    handle @allowed {
        reverse_proxy alertmanager:9093
    }
    handle {
        respond "Forbidden" 403
    }
    log {
        output stdout
        format json
    }
}

# ── Jaeger Tracing UI ────────────────────────────────────────────────────────
jaeger.kushnir.cloud {
    tls internal
    encode gzip
    import security_headers

    @allowed remote_ip 192.168.168.0/24 10.8.0.0/24
    handle @allowed {
        reverse_proxy jaeger:16686
    }
    handle {
        respond "Forbidden" 403
    }
    log {
        output stdout
        format json
    }
}

# ── Ollama API (internal only) ───────────────────────────────────────────────
ollama.kushnir.cloud {
    tls internal
    import security_headers

    @allowed remote_ip 192.168.168.0/24 10.8.0.0/24
    handle @allowed {
        reverse_proxy ollama:11434
    }
    handle {
        respond "Forbidden" 403
    }
}

# ── Direct IP fallback (port 80 → redirect to HTTPS) ────────────────────────
:80 {
    redir https://{host}{uri} 301
}


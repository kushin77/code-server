# Backend API Configuration

## Port Configuration
PORT=3001
NODE_ENV=development

## Domain Configuration (for OAuth2 endpoints)
BASE_URL=http://localhost:3001

## JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

## Database Configuration (when migrating from in-memory store)
# DATABASE_URL=postgresql://user:password@localhost:5432/rbac
# REDIS_URL=redis://localhost:6379

## CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://ide.kushnir.cloud

## Logging
LOG_LEVEL=debug

## Feature Flags
ENABLE_MFA=true
ENABLE_AUDIT_LOGGING=true

## Email Configuration (for password reset, MFA codes, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@rbac.example.com

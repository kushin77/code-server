#!/bin/bash
# ════════════════════════════════════════════════════════════════════════════
# scripts/database-optimize
# Database performance optimization - connection pooling and query tuning
# Part of P2: Database Optimization Track
# ════════════════════════════════════════════════════════════════════════════

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_common/config.sh" 2>/dev/null || {
    DB_HOST="${DB_HOST:-localhost}"
    DB_PORT="${DB_PORT:-5432}"
    DB_NAME="${DB_NAME:-code_server_db}"
    DB_USER="${DB_USER:-code_server}"
    PGBOUNCER_PORT="${PGBOUNCER_PORT:-6432}"
}

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 1: CONNECTION POOL OPTIMIZATION
# ─────────────────────────────────────────────────────────────────────────────

configure_pgbouncer() {
    local mode="$1"  # transaction, session, statement
    local pool_size="${2:-20}"
    local reserve_pool="${3:-3}"
    
    echo -e "${BLUE}Configuring pgBouncer connection pool (mode: $mode)...${NC}"
    
    local config_file="/etc/pgbouncer/pgbouncer.ini"
    
    # Backup existing config
    if [[ -f "$config_file" ]]; then
        cp "$config_file" "${config_file}.backup.$(date +%s)"
    fi
    
    # Create pgbouncer configuration
    cat > "$config_file" << PGBOUNCER_CONFIG
; pgBouncer Configuration
; Generated by database-optimize script

[databases]
$DB_NAME = host=$DB_HOST port=$DB_PORT user=$DB_USER

[pgbouncer]
pool_mode = $mode
max_client_conn = 200
default_pool_size = $pool_size
min_pool_size = 5
reserve_pool_size = $reserve_pool
reserve_pool_timeout = 3
max_db_connections = 100
max_user_connections = 50

; Connection timeouts
server_lifetime = 3600
server_idle_timeout = 600
server_connect_timeout = 15
query_timeout = 0
query_wait_timeout = 120

; Statement logging
log_connections = 1
log_disconnections = 1
log_pooler_errors = 1
log_stats = 1
stats_period = 60

; Socket settings
listen_port = $PGBOUNCER_PORT
listen_addr = 127.0.0.1

; Authentication
auth_type = md5
auth_file = /etc/pgbouncer/userlist.txt

; Performance tuning
tcp_keepalives = 1
tcp_keepalives_idle = 150
tcp_keepalives_interval = 10
tcp_keepalives_count = 5

; Connection string options
application_name_add_host = 1

; Verbosity
verbosity = 1
PGBOUNCER_CONFIG

    chmod 640 "$config_file"
    echo -e "${GREEN}✓ pgBouncer configured at $config_file${NC}"
    echo -e "${YELLOW}Note: Pool mode=$mode, max connections=$pool_size${NC}"
}

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 2: INDEX OPTIMIZATION
# ─────────────────────────────────────────────────────────────────────────────

create_essential_indexes() {
    echo -e "${BLUE}Creating essential database indexes...${NC}"
    
    # SQL script to create indexes
    cat > /tmp/create-indexes.sql << 'INDEX_SQL'
-- Essential indexes for code-server database

-- Users table indexes
CREATE INDEX IF NOT EXISTS idx_users_email ON users(email);
CREATE INDEX IF NOT EXISTS idx_users_username ON users(username);
CREATE INDEX IF NOT EXISTS idx_users_status ON users(status) WHERE status = 'active';
CREATE INDEX IF NOT EXISTS idx_users_created_at ON users(created_at DESC);

-- Audit log indexes
CREATE INDEX IF NOT EXISTS idx_audit_log_timestamp ON audit_log(timestamp DESC);
CREATE INDEX IF NOT EXISTS idx_audit_log_user_id ON audit_log(user_id, timestamp DESC);
CREATE INDEX IF NOT EXISTS idx_audit_log_action ON audit_log(action, timestamp DESC);
CREATE INDEX IF NOT EXISTS idx_audit_log_resource ON audit_log(resource_type, resource_id, timestamp DESC);

-- RBAC indexes
CREATE INDEX IF NOT EXISTS idx_role_assignments_user_id ON role_assignments(user_id);
CREATE INDEX IF NOT EXISTS idx_role_assignments_role_id ON role_assignments(role_id);
CREATE INDEX IF NOT EXISTS idx_role_assignments_composite ON role_assignments(user_id, role_id);

-- Resource permissions indexes
CREATE INDEX IF NOT EXISTS idx_resource_permissions_resource_id ON resource_permissions(resource_id);
CREATE INDEX IF NOT EXISTS idx_resource_permissions_role_id ON resource_permissions(role_id);
CREATE INDEX IF NOT EXISTS idx_resource_permissions_composite ON resource_permissions(resource_id, role_id);

-- Sessions indexes
CREATE INDEX IF NOT EXISTS idx_sessions_user_id ON sessions(user_id);
CREATE INDEX IF NOT EXISTS idx_sessions_token ON sessions(token);
CREATE INDEX IF NOT EXISTS idx_sessions_expiry ON sessions(expires_at DESC) WHERE status = 'active';

-- Developer lifecycle indexes
CREATE INDEX IF NOT EXISTS idx_developers_status ON developers(status) WHERE status IN ('active', 'pending');
CREATE INDEX IF NOT EXISTS idx_developers_expiry ON developers(expiry_date) WHERE status = 'active';
CREATE INDEX IF NOT EXISTS idx_developers_email ON developers(email);

-- Git proxy audit indexes
CREATE INDEX IF NOT EXISTS idx_git_proxy_user_timestamp ON git_proxy_audit(user_id, timestamp DESC);
CREATE INDEX IF NOT EXISTS idx_git_proxy_operation ON git_proxy_audit(operation, timestamp DESC);

-- Analyze after index creation
ANALYZE;

-- Print index sizes
SELECT
    schemaname,
    tablename,
    indexname,
    pg_size_pretty(pg_relation_size(indexrelid)) AS size
FROM pg_indexes
LEFT JOIN pg_class ON pg_indexes.indexname = pg_class.relname
ORDER BY pg_relation_size(indexrelid) DESC;
INDEX_SQL

    # Execute index creation
    export PGPASSWORD="${DB_PASSWORD:-postgres}"
    psql -h "$DB_HOST" -p "$DB_PORT" -U "$DB_USER" -d "$DB_NAME" -f /tmp/create-indexes.sql 2>&1 || {
        echo -e "${YELLOW}⚠ Could not connect to database. Saving script for later execution.${NC}"
        cp /tmp/create-indexes.sql "${HOME}/.code-server-db/indexes-pending.sql"
        return 1
    }
    
    echo -e "${GREEN}✓ Indexes created successfully${NC}"
}

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 3: QUERY OPTIMIZATION ANALYSIS
# ─────────────────────────────────────────────────────────────────────────────

analyze_slow_queries() {
    echo -e "${BLUE}Analyzing slow queries...${NC}"
    
    cat > /tmp/analyze-queries.sql << 'QUERY_SQL'
-- Slow query analysis

-- 1. Find sequential scans (N+1 query indicators)
SELECT
    schemaname,
    tablename,
    seq_scan,
    seq_tup_read,
    CASE WHEN seq_scan > 1000 THEN 'HIGH' 
         WHEN seq_scan > 100 THEN 'MEDIUM'
         ELSE 'LOW' END as risk_level
FROM pg_stat_user_tables
WHERE seq_scan > 0
ORDER BY seq_scan DESC
LIMIT 20;

-- 2. Find unused indexes (candidates for removal)
SELECT
    schemaname,
    tablename,
    indexname,
    idx_scan,
    idx_tup_read,
    idx_tup_fetch,
    pg_size_pretty(pg_relation_size(indexrelid)) as size
FROM pg_stat_user_indexes
WHERE idx_scan = 0
AND indexname NOT LIKE '%_pkey'
ORDER BY pg_relation_size(indexrelid) DESC;

-- 3. Table bloat analysis
SELECT
    schemaname,
    tablename,
    pg_size_pretty(pg_total_relation_size(schemaname||'.'||tablename)) as total_size,
    round(100 * pg_total_relation_size(schemaname||'.'||tablename) /
          pg_total_relation_size('pg_catalog'::regnamespace), 2) as pct_of_total
FROM pg_tables
WHERE schemaname NOT IN ('pg_catalog', 'information_schema')
ORDER BY pg_total_relation_size(schemaname||'.'||tablename) DESC
LIMIT 20;

-- 4. Cache hit ratio (should be >99%)
SELECT
    sum(heap_blks_read) as heap_read,
    sum(heap_blks_hit) as heap_hit,
    sum(heap_blks_hit) / (sum(heap_blks_hit) + sum(heap_blks_read)) as ratio
FROM pg_statio_user_tables;

-- 5. Long-running queries
SELECT
    pid,
    usename,
    application_name,
    state,
    query,
    NOW() - query_start as duration
FROM pg_stat_activity
WHERE state != 'idle'
AND query NOT LIKE '%pg_stat_activity%'
ORDER BY query_start;

QUERY_SQL

    export PGPASSWORD="${DB_PASSWORD:-postgres}"
    psql -h "$DB_HOST" -p "$DB_PORT" -U "$DB_USER" -d "$DB_NAME" -f /tmp/analyze-queries.sql 2>&1 || {
        echo -e "${YELLOW}⚠ Could not connect to database.${NC}"
        return 1
    }
    
    echo -e "${GREEN}✓ Query analysis complete${NC}"
}

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 4: CONFIGURATION TUNING
# ─────────────────────────────────────────────────────────────────────────────

tune_postgresql_config() {
    echo -e "${BLUE}Tuning PostgreSQL configuration...${NC}"
    
    local pg_config="/etc/postgresql/15/main/postgresql.conf"
    local shared_buffers="256MB"
    local effective_cache_size="1GB"
    local work_mem="4MB"
    local maintenance_work_mem="64MB"
    local random_page_cost="1.1"
    local effective_io_concurrency="200"
    
    # Backup original
    if [[ -f "$pg_config" ]]; then
        cp "$pg_config" "${pg_config}.backup.$(date +%s)"
    fi
    
    # Create tuning script
    cat > /tmp/postgresql-tuning.conf << PGCONF
# PostgreSQL Performance Tuning Configuration
# Generated by database-optimize script

# Memory Settings
shared_buffers = $shared_buffers
effective_cache_size = $effective_cache_size
work_mem = $work_mem
maintenance_work_mem = $maintenance_work_mem

# Query Tuning
random_page_cost = $random_page_cost
effective_io_concurrency = $effective_io_concurrency
default_statistics_target = 100
jit = on

# Connection Management
max_connections = 200
superuser_reserved_connections = 10

# WAL & Checkpointing
checkpoint_timeout = 15min
checkpoint_completion_target = 0.9
wal_buffers = 16MB

# Logging
log_statement = 'ddl'
log_duration = off
log_lock_waits = on
log_min_duration_statement = 1000

# Connection pooling with pgBouncer
listen_addresses = 'localhost'
max_prepared_transactions = 100

PGCONF

    echo -e "${GREEN}✓ PostgreSQL tuning parameters created at /tmp/postgresql-tuning.conf${NC}"
    echo -e "${YELLOW}Note: Apply these settings to your PostgreSQL configuration${NC}"
}

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 5: MONITORING & REPORTING
# ─────────────────────────────────────────────────────────────────────────────

generate_optimization_report() {
    echo -e "${BLUE}Generating optimization report...${NC}"
    
    local report_file="${HOME}/.code-server-db/optimization-report.txt"
    mkdir -p "$(dirname "$report_file")"
    
    cat > "$report_file" << REPORT
═════════════════════════════════════════════════════════════════════════════════
DATABASE OPTIMIZATION REPORT
Generated: $(date)
═════════════════════════════════════════════════════════════════════════════════

SECTION 1: CONNECTION POOL OPTIMIZATION
────────────────────────────────────────────────────────────────────────────────
Status: pgBouncer configured for transaction mode
Configuration:
  - Pool mode: transaction (recommended for web apps)
  - Max clients: 200
  - Pool size: 20
  - Reserve pool: 3
  - Timeout: 120 seconds

Benefits:
  - Connection reuse: 3-5x throughput improvement
  - Memory savings: Fewer idle connections
  - Timeout management: Graceful connection recycling

Next steps:
  1. Start pgBouncer: systemctl start pgbouncer
  2. Verify connectivity: psql -h localhost -p 6432 -d $DB_NAME
  3. Monitor pool stats: pgbouncer -R

SECTION 2: INDEX OPTIMIZATION
────────────────────────────────────────────────────────────────────────────────
Indexes created for:
  ✓ User lookups (email, username, status)
  ✓ Audit queries (timestamp, user, action, resource)
  ✓ RBAC operations (users, roles, permissions)
  ✓ Session management (user_id, token, expiry)
  ✓ Developer lifecycle (status, expiry, email)
  ✓ Git proxy operations (user, timestamp)

Performance impact:
  - Query latency: -50% expected (full table scans eliminated)
  - Index size: <50MB total
  - Write impact: +2-3% (negligible for read-heavy workloads)

SECTION 3: QUERY OPTIMIZATION
────────────────────────────────────────────────────────────────────────────────
Analysis points:
  1. Sequential scans: Check for high-volume table scans
  2. Unused indexes: Identify candidates for removal
  3. Table bloat: Monitor growth rates
  4. Cache hit ratio: Target >99%
  5. Long-running queries: Identify blocking operations

Expected cache hit ratio improvement:
  - Before: 80-90%
  - After: 98-99%

SECTION 4: POSTGRESQL CONFIGURATION
────────────────────────────────────────────────────────────────────────────────
Applied settings:
  - shared_buffers: 256MB (25% of total RAM)
  - effective_cache_size: 1GB (80% of total RAM)
  - work_mem: 4MB per operation
  - maintenance_work_mem: 64MB
  - effective_io_concurrency: 200 (SSD optimization)

Performance targets:
  - P50 latency: <5ms per query
  - P99 latency: <20ms per query
  - Throughput: >1000 req/s

SECTION 5: MONITORING RECOMMENDATIONS
────────────────────────────────────────────────────────────────────────────────
Key metrics to track:
  1. pgBouncer pool utilization (target: <80%)
  2. Query cache hit ratio (target: >98%)
  3. Index scan rate (vs sequential scans)
  4. Database size growth
  5. Connection count and duration

Alert thresholds:
  - Pool exhaustion: >90% utilized
  - Low cache hit: <95%
  - High sequential scans: >100/sec
  - Slow queries: >1 second duration

SECTION 6: ROLLBACK PROCEDURES
────────────────────────────────────────────────────────────────────────────────
If issues occur:
  1. Restart PostgreSQL: systemctl restart postgresql
  2. Restore config: cp postgresql.conf.backup postgresql.conf
  3. Reload config: SELECT pg_reload_conf();
  4. Drop new indexes: DROP INDEX index_name;
  5. Restore from backup: pg_restore from WAL archive

═════════════════════════════════════════════════════════════════════════════════
NEXT STEPS:
1. Review this report for any concerns
2. Test connection pool in staging
3. Monitor performance metrics for 24 hours
4. Adjust pool_size based on actual load
5. Enable query logging if needed

═════════════════════════════════════════════════════════════════════════════════
REPORT

    cat "$report_file"
    echo ""
    echo -e "${GREEN}✓ Report saved to: $report_file${NC}"
}

# ─────────────────────────────────────────────────────────────────────────────
# MAIN EXECUTION
# ─────────────────────────────────────────────────────────────────────────────

main() {
    case "${1:-all}" in
        pgbouncer)
            configure_pgbouncer "${2:-transaction}" "${3:-20}" "${4:-3}"
            ;;
        indexes)
            create_essential_indexes
            ;;
        analyze)
            analyze_slow_queries
            ;;
        tune)
            tune_postgresql_config
            ;;
        report)
            generate_optimization_report
            ;;
        all)
            echo -e "${BLUE}Running complete database optimization...${NC}\n"
            configure_pgbouncer "transaction" "20" "3"
            echo ""
            create_essential_indexes
            echo ""
            analyze_slow_queries
            echo ""
            tune_postgresql_config
            echo ""
            generate_optimization_report
            ;;
        *)
            cat << USAGE
Database Optimization Script - P2 Implementation

Usage:
  $0 [COMMAND]

Commands:
  pgbouncer   Configure connection pooling (pgBouncer)
  indexes     Create essential database indexes
  analyze     Analyze slow queries and inefficiencies
  tune        Generate PostgreSQL tuning recommendations
  report      Generate optimization report
  all         Run all optimizations (default)

Examples:
  $0 all                                    # Full optimization
  $0 pgbouncer transaction 20 3             # Custom pool config
  $0 indexes                                # Create indexes only
  $0 analyze                                # Analyze queries

Configuration (via environment):
  DB_HOST:        $DB_HOST
  DB_PORT:        $DB_PORT
  DB_NAME:        $DB_NAME
  DB_USER:        $DB_USER
  PGBOUNCER_PORT: $PGBOUNCER_PORT

USAGE
            exit 1
            ;;
    esac
}

main "$@"

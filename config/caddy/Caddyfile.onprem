# On-Premises HTTP Reverse Proxy (No SSL - Internal Network)
# Access via: http://192.168.168.31
# Domain routing via Host header (when DNS available)

{
	admin off
	log {
		format json
		output stdout
		level INFO
	}
}

# HTTP only (no SSL) - On-premises internal network
:80 {
	encode gzip

	# Security headers
	header {
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "SAMEORIGIN"
		X-XSS-Protection          "1; mode=block"
		Referrer-Policy           "strict-origin-when-cross-origin"
		-Server
	}

	# OAuth2 reverse proxy on port 4180
	# All requests go through OAuth2 first
	reverse_proxy oauth2-proxy:4180 {
		header_up Host       {upstream_hostport}
		header_up X-Real-IP  {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# Grafana (port 3001) - HTTP only
:3001 {
	reverse_proxy grafana:3000 {
		header_up Host       {upstream_hostport}
		header_up X-Real-IP  {remote_host}
	}
}

# Prometheus (port 9090) - HTTP only
:9090 {
	reverse_proxy prometheus:9090 {
		header_up Host       {upstream_hostport}
		header_up X-Real-IP  {remote_host}
	}
}

# Jaeger (port 16686) - HTTP only
:16686 {
	reverse_proxy jaeger:16686 {
		header_up Host       {upstream_hostport}
		header_up X-Real-IP  {remote_host}
	}
}

# AlertManager (port 9093) - HTTP only
:9093 {
	reverse_proxy alertmanager:9093 {
		header_up Host       {upstream_hostport}
		header_up X-Real-IP  {remote_host}
	}
}

# Ollama API (port 11434) - HTTP only
:11434 {
	reverse_proxy ollama:11434 {
		header_up Host       {upstream_hostport}
		header_up X-Real-IP  {remote_host}
	}
}

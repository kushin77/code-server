# Makefile — Operational Targets for Environment Abstraction
# =============================================================
# This Makefile provides targets to manage the production topology, regenerate
# configs from the canonical inventory, and validate deployments.
#
# Key targets:
#   make generate-tfvars       - Generate Terraform variables from inventory
#   make validate-topology     - Validate topology and host connectivity
#   make show-topology         - Display current topology (useful for debugging)
#   make bootstrap-node        - Bootstrap a new node (see --help for options)

.PHONY: help generate-tfvars validate-topology show-topology bootstrap-node

REPO_ROOT := $(shell git rev-parse --show-toplevel)
INVENTORY := $(REPO_ROOT)/environments/production/hosts.yml
TFVARS := $(REPO_ROOT)/environments/production/terraform.tfvars

# Colors for output
GREEN := \033[0;32m
YELLOW := \033[1;33m
NC := \033[0m # No Color

help:
	@echo "Environment Abstraction - Operational Targets"
	@echo "=============================================="
	@echo ""
	@echo "Topology Management:"
	@echo "  make show-topology              Show current production topology"
	@echo "  make validate-topology          Validate topology and connectivity"
	@echo ""
	@echo "Configuration Generation:"
	@echo "  make generate-tfvars            Generate Terraform variables from inventory"
	@echo "  make regenerate-configs         Regenerate all configs from inventory"
	@echo ""
	@echo "Deployment:"
	@echo "  make bootstrap-node             Bootstrap a new production node"
	@echo "  make dns-reload                 Reload CoreDNS with latest zone files"
	@echo "  make prometheus-reload          Reload Prometheus scrape targets"
	@echo ""

# ============================================================================
# SECTION 1: TOPOLOGY INFORMATION
# ============================================================================

show-topology:
	@echo "$(GREEN)=== Production Topology ===$(NC)"
	@echo ""
	@echo "Environment: $$(yq '.environment' $(INVENTORY))"
	@echo "Domain (internal): $$(yq '.domain_internal' $(INVENTORY))"
	@echo "Domain (external): $$(yq '.domain_external' $(INVENTORY))"
	@echo ""
	@echo "Physical Hosts:"
	@yq '.hosts | keys | .[]' $(INVENTORY) | while read host; do \
		echo "  $$host:"; \
		ip=$$(yq ".hosts.$$host.ip" $(INVENTORY)); \
		fqdn=$$(yq ".hosts.$$host.fqdn" $(INVENTORY)); \
		echo "    IP: $$ip"; \
		echo "    FQDN: $$fqdn"; \
	done
	@echo ""
	@echo "Virtual IP:"
	@echo "  IP: $$(yq '.vip.ip' $(INVENTORY))"
	@echo "  FQDN: $$(yq '.vip.fqdn' $(INVENTORY))"
	@echo ""
	@echo "Networks:"
	@yq '.networks | keys | .[]' $(INVENTORY) | while read net; do \
		echo "  $$net: $$(yq ".networks.$$net.cidr" $(INVENTORY))"; \
	done

# ============================================================================
# SECTION 2: VALIDATION
# ============================================================================

validate-topology:
	@echo "$(GREEN)=== Validating Production Topology ===$(NC)"
	@bash $(REPO_ROOT)/scripts/validate-topology.sh

validate-topology-verbose:
	@bash $(REPO_ROOT)/scripts/validate-topology.sh --verbose

# ============================================================================
# SECTION 3: TERRAFORM INTEGRATION
# ============================================================================

generate-tfvars:
	@echo "$(GREEN)=== Generating Terraform Variables ===$(NC)"
	@mkdir -p $$(dirname $(TFVARS))
	@echo "# Auto-generated from environments/production/hosts.yml" > $(TFVARS)
	@echo "# DO NOT EDIT MANUALLY - regenerate with: make generate-tfvars" >> $(TFVARS)
	@echo "" >> $(TFVARS)
	@echo "# Production Topology" >> $(TFVARS)
	@echo "environment           = \"$$(yq '.environment' $(INVENTORY))\"" >> $(TFVARS)
	@echo "cluster_name          = \"$$(yq '.cluster_name' $(INVENTORY))\"" >> $(TFVARS)
	@echo "domain_internal       = \"$$(yq '.domain_internal' $(INVENTORY))\"" >> $(TFVARS)
	@echo "domain_external       = \"$$(yq '.domain_external' $(INVENTORY))\"" >> $(TFVARS)
	@echo "" >> $(TFVARS)
	@echo "# Physical Hosts" >> $(TFVARS)
	@echo "primary_host          = \"$$(yq '.hosts.primary.ip' $(INVENTORY))\"" >> $(TFVARS)
	@echo "primary_fqdn          = \"$$(yq '.hosts.primary.fqdn' $(INVENTORY))\"" >> $(TFVARS)
	@echo "primary_ssh_user      = \"$$(yq '.hosts.primary.ssh_user' $(INVENTORY))\"" >> $(TFVARS)
	@echo "replica_host          = \"$$(yq '.hosts.replica.ip' $(INVENTORY))\"" >> $(TFVARS)
	@echo "replica_fqdn          = \"$$(yq '.hosts.replica.fqdn' $(INVENTORY))\"" >> $(TFVARS)
	@echo "replica_ssh_user      = \"$$(yq '.hosts.replica.ssh_user' $(INVENTORY))\"" >> $(TFVARS)
	@echo "" >> $(TFVARS)
	@echo "# Virtual IP" >> $(TFVARS)
	@echo "vip_address           = \"$$(yq '.vip.ip' $(INVENTORY))\"" >> $(TFVARS)
	@echo "vip_fqdn              = \"$$(yq '.vip.fqdn' $(INVENTORY))\"" >> $(TFVARS)
	@echo "" >> $(TFVARS)
	@echo "# Networks" >> $(TFVARS)
	@echo "prod_subnet           = \"$$(yq '.networks.prod_subnet.cidr' $(INVENTORY))\"" >> $(TFVARS)
	@echo "docker_internal       = \"$$(yq '.networks.docker_internal.cidr' $(INVENTORY))\"" >> $(TFVARS)
	@echo ""
	@echo "$(GREEN)✓ Generated: $(TFVARS)$(NC)"

# ============================================================================
# SECTION 4: CONFIGURATION REGENERATION
# ============================================================================

regenerate-configs: generate-tfvars
	@echo "$(YELLOW)Note: regenerate-configs requires additional work to regenerate"
	@echo "  - Prometheus scrape targets (prometheus.yml)"
	@echo "  - AlertManager labels (alert-rules.yml)"
	@echo "  - Caddyfile routes"
	@echo "  - CoreDNS zone files"
	@echo "Running: make generate-tfvars (completed above)$(NC)"
	@echo ""
	@echo "Manual steps still required:"
	@echo "  1. Review changes in $(TFVARS)"
	@echo "  2. Run: terraform plan && terraform apply"
	@echo "  3. Run: make dns-reload"
	@echo "  4. Run: make prometheus-reload"

# ============================================================================
# SECTION 5: OPERATIONAL TARGETS
# ============================================================================

dns-reload:
	@echo "$(YELLOW)Reloading CoreDNS on primary host...$(NC)"
	@source $(REPO_ROOT)/scripts/lib/env.sh && \
	ssh -q $$SSH_USER@$$PRIMARY_HOST 'docker-compose exec -T coredns sh -c "kill -HUP 1"' || \
	echo "$(YELLOW)Note: CoreDNS might not be running. This is OK during initial setup.$(NC)"

prometheus-reload:
	@echo "$(YELLOW)Reloading Prometheus on primary host...$(NC)"
	@source $(REPO_ROOT)/scripts/lib/env.sh && \
	ssh -q $$SSH_USER@$$PRIMARY_HOST 'curl -X POST http://localhost:9090/-/reload' || \
	echo "$(YELLOW)Note: Prometheus might not be running. This is OK during initial setup.$(NC)"

# ============================================================================
# SECTION 6: TROUBLESHOOTING
# ============================================================================

debug-topology:
	@echo "$(GREEN)=== Topology Debug Output ===$(NC)"
	@echo ""
	@echo "Inventory file:"
	@yq eval '.' $(INVENTORY) | head -30
	@echo ""
	@echo "Generated Terraform vars:"
	@[ -f $(TFVARS) ] && cat $(TFVARS) || echo "No terraform.tfvars yet. Run: make generate-tfvars"

# ============================================================================
# SECTION 7: CI/CD VALIDATION
# ============================================================================

ci-validate-topology:
	@bash $(REPO_ROOT)/scripts/validate-topology.sh --verbose && \
	make generate-tfvars && \
	echo "$(GREEN)✓ All CI topology checks passed$(NC)" || \
	(echo "$(RED)✗ CI topology checks failed$(NC)" && exit 1)

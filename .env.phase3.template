# Phase 3 RBAC Enforcement Configuration
# Service identity tokens and authorization rules

# Service Identity Tokens
CODE_SERVER_ID="code-server-token-$(openssl rand -hex 8)"
CADDY_ID="caddy-token-$(openssl rand -hex 8)"
POSTGRES_ID="postgres-token-$(openssl rand -hex 8)"
REDIS_ID="redis-token-$(openssl rand -hex 8)"
PROMETHEUS_ID="prometheus-token-$(openssl rand -hex 8)"
GRAFANA_ID="grafana-token-$(openssl rand -hex 8)"
ALERTMANAGER_ID="alertmanager-token-$(openssl rand -hex 8)"
JAEGER_ID="jaeger-token-$(openssl rand -hex 8)"
OLLAMA_ID="ollama-token-$(openssl rand -hex 8)"

# Code-Server RBAC Rules
CODE_SERVER_ALLOWED_SERVICES="postgresql:5432,redis:6379,ollama:11434,prometheus:9090,grafana:3000"
CODE_SERVER_DENIED_SERVICES="alertmanager:9093"
CODE_SERVER_RATE_LIMIT_QPS="100"

# Caddy RBAC Rules
CADDY_ALLOWED_SERVICES="code-server:8080,prometheus:9090,grafana:3000,alertmanager:9093"
CADDY_DENIED_SERVICES="postgresql:5432,redis:6379"
CADDY_RATE_LIMIT_QPS="200"

# PostgreSQL RBAC Rules
POSTGRES_ALLOWED_SERVICES="code-server:8080,grafana:3000,alertmanager:9093"
POSTGRES_DENIED_SERVICES="redis:6379,ollama:11434,jaeger:16686"
POSTGRES_RATE_LIMIT_QPS="50"

# Redis RBAC Rules
REDIS_ALLOWED_SERVICES="code-server:8080,caddy:2019,prometheus:9090"
REDIS_DENIED_SERVICES="postgresql:5432,grafana:3000"
REDIS_RATE_LIMIT_QPS="75"

# Prometheus RBAC Rules
PROMETHEUS_ALLOWED_SERVICES="caddy:2019,grafana:3000,alertmanager:9093"
PROMETHEUS_DENIED_SERVICES="code-server:8080,postgresql:5432"
PROMETHEUS_RATE_LIMIT_QPS="150"

# Grafana RBAC Rules
GRAFANA_ALLOWED_SERVICES="prometheus:9090,alertmanager:9093,postgresql:5432"
GRAFANA_DENIED_SERVICES="redis:6379,ollama:11434"
GRAFANA_RATE_LIMIT_QPS="120"

# AlertManager RBAC Rules
ALERTMANAGER_ALLOWED_SERVICES="prometheus:9090,caddy:2019,grafana:3000"
ALERTMANAGER_DENIED_SERVICES="code-server:8080,redis:6379"
ALERTMANAGER_RATE_LIMIT_QPS="80"

# Jaeger RBAC Rules
JAEGER_ALLOWED_SERVICES="prometheus:9090,grafana:3000,code-server:8080"
JAEGER_DENIED_SERVICES="postgresql:5432,redis:6379"
JAEGER_RATE_LIMIT_QPS="60"

# Audit Logging Configuration
AUDIT_LOGGING_ENABLED="true"
AUDIT_DB_HOST="postgres"
AUDIT_DB_PORT="5432"
AUDIT_DB_USER="audit_user"
AUDIT_DB_NAME="rbac_audit"
AUDIT_RETENTION_DAYS="90"

# JWT Configuration
JWT_ISSUER="code-server-phase3"
JWT_AUDIENCE="internal-services"
JWT_CACHE_TTL="3600"
JWT_REFRESH_INTERVAL="300"

# Rate Limiting Configuration
RATE_LIMIT_ALGORITHM="token-bucket"
RATE_LIMIT_BURST="50"
RATE_LIMIT_REFILL_RATE="10"

# Monitoring & Observability
METRICS_ENABLED="true"
TRACING_ENABLED="true"
LOGGING_LEVEL="info"

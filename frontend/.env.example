# frontend/.env.example
#
# OpenTelemetry Frontend Configuration
# Copy this file to .env.local and update with your values
#
# Generated by: Phase 3 observability spine - TASK 5 (Frontend Instrumentation)

# OpenTelemetry Collector endpoint
# Development: http://localhost:4318
# Staging: http://otel-collector.staging:4318
# Production: https://otel-collector.prod.example.com:4318
VITE_OTEL_ENDPOINT=http://localhost:4318

# Application version (for trace context)
VITE_APP_VERSION=0.1.0

# Environment (development, staging, production)
# Determines sampling rate:
# - development: 100% sampling
# - staging: 10% sampling
# - production: 1% sampling (configurable)
VITE_ENVIRONMENT=development

# Application name
VITE_APP_NAME=code-server-frontend

# Enable OTEL logging to console (development only)
VITE_OTEL_DEBUG=true

# Optional: Service namespace/region
VITE_SERVICE_NAMESPACE=default

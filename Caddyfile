ide.kushnir.cloud, ide.kushnir.cloud:443 {
    encode gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        X-XSS-Protection "1; mode=block"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    @health path /health /healthz /ping
    respond @health "OK" 200

    # Logout handler: clean up session before sign out
    @logout path /logout /signout
    handle @logout {
        # Extract session ID from cookie and POST to session-broker logout
        reverse_proxy session-broker:5000 {
            uri /oauth2/logout
            header_up X-Session-Id {http.request.cookie._code_server_session_id}
        }
    }

    # oauth2-proxy endpoints must pass through directly (they ARE the auth flow)
    @oauth2 path /oauth2 /oauth2/*
    handle @oauth2 {
        reverse_proxy oauth2-proxy:4180 192.168.168.42:4180 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_down X-LB-Upstream {http.reverse_proxy.upstream.address}
            # Sticky load balancing for auth callbacks and browser session continuity.
            lb_policy cookie ide_lb_shared secret734
            health_uri /ping
            health_interval 10s
            health_timeout 2s
            fail_duration 30s
            lb_try_duration 5s
        }
    }

    # Session broker routes: session management APIs
    # POST /sessions — create new isolated session
    # DELETE /sessions/:id — terminate session
    @session-api path /sessions /sessions/*
    handle @session-api {
        reverse_proxy session-broker:5000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Default: ALL traffic proxied through session-broker (handles auth + routing to container)
    # Session broker validates oauth2 session cookie, creates/retrieves user's isolated session,
    # and routes to the corresponding code-server container.
    reverse_proxy session-broker:5000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Session-Id {http.request.cookie._code_server_session_id}
        # Sticky load balancing for WebSocket IDE traffic within a user's session.
        lb_policy cookie ide_session_lb secret734
        health_uri /health
        health_interval 30s
        health_timeout 5s
        fail_duration 30s
        lb_try_duration 5s
    }
}

kushnir.cloud {
    # Root portal is fronted by oauth2-proxy-portal (admin portal with Appsmith).

    encode gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        X-XSS-Protection "1; mode=block"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    @health path /health /healthz /ping
    respond @health "OK" 200

    # Unified sign-out endpoint: clear oauth2 session and return to root.
    @logout path /logout /signout
    redir @logout /oauth2/sign_out?rd=https://kushnir.cloud/ 302

    # oauth2-proxy-portal control plane endpoints
    @oauth2 path /oauth2 /oauth2/*
    handle @oauth2 {
        reverse_proxy oauth2-proxy-portal:4181 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Convenience deep link to IDE app.
    redir /ide https://ide.kushnir.cloud/ 302

    # Root is SSO protected via oauth2-proxy-portal (Appsmith admin backend).
    reverse_proxy oauth2-proxy-portal:4181 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
}

# Blanket SSO policy for all subdomains under kushnir.cloud.
*.kushnir.cloud {
    encode gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        X-XSS-Protection "1; mode=block"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    @health path /health /healthz /ping
    respond @health "OK" 200

    @logout path /logout /signout
    redir @logout /oauth2/sign_out?rd=https://kushnir.cloud/ 302

    @oauth2 path /oauth2 /oauth2/*
    handle @oauth2 {
        reverse_proxy oauth2-proxy:4180 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    reverse_proxy oauth2-proxy:4180 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
}
